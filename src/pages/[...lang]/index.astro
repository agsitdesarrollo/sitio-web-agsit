---
import { Image } from 'astro:assets';
import AboutHorizontalSection from '../../components/about/AboutHorizontalSection.astro';
import ContactDrawer from '../../components/contact/ContactDrawer.astro';
import FinalContactSection from '../../components/final-contact/FinalContactSection.astro';
import Footer from '../../components/footer/Footer.astro';
import HeroSection from '../../components/hero/HeroSection.astro';
import Header from '../../components/navigation/Header.astro';
import ServicesSection from '../../components/services/ServicesSection.astro';
import VideoStorySection from '../../components/video-story/VideoStorySection.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import logoImage from '../../assets/images/logo-asit.webp';
import { getAboutContent } from '../../data/about';
import { getContactCopy } from '../../data/contact';
import { getFooterCopy } from '../../data/footer';
import { getHeroContent } from '../../data/hero';
import { getServicesContent } from '../../data/services';
import { getSiteMetadata, siteMetadataByLang } from '../../data/siteMetadata';
import { getStoryLines } from '../../data/videoStory';
import { useTranslations } from '../../i18n/utils';
import type { SupportedLang } from '../../i18n/ui';

export function getStaticPaths() {
  return [
    { params: { lang: undefined }, props: { lang: 'es' } },
    { params: { lang: 'en' }, props: { lang: 'en' } },
  ];
}

type Props = {
  lang: SupportedLang;
};

const { lang } = Astro.props;
const metadata = getSiteMetadata(lang);
const aboutContent = getAboutContent(lang);
const contactCopy = getContactCopy(lang);
const footerCopy = getFooterCopy(lang);
const heroContent = getHeroContent(lang);
const servicesContent = getServicesContent(lang);
const storyLines = getStoryLines(lang);
const t = useTranslations(lang);
const alternates = [
  { lang: 'es-MX', href: siteMetadataByLang.es.canonicalUrl },
  { lang: 'en', href: siteMetadataByLang.en.canonicalUrl },
  { lang: 'x-default', href: siteMetadataByLang.es.canonicalUrl },
];
---

<SiteLayout
  title={metadata.title}
  description={metadata.description}
  canonicalUrl={metadata.canonicalUrl}
  htmlLang={metadata.htmlLang}
  locale={metadata.locale}
  alternates={alternates}
>
  <div class="app-shell" data-scroll-root>
    <Header lang={lang} />
    <main>
      <HeroSection copy={heroContent} />
      <ServicesSection content={servicesContent} />
      <AboutHorizontalSection content={aboutContent} />
      <VideoStorySection lines={storyLines} lang={lang} />
      <FinalContactSection copy={contactCopy} />
      <button
        class="scroll-consult-logo js-scroll-consult-logo"
        type="button"
        data-contact-trigger
        aria-label={t('floatingCta.label')}
      >
        <span class="scroll-consult-logo-mark" aria-hidden="true">
          <Image src={logoImage} alt="" loading="lazy" draggable="false" />
        </span>
        <span class="scroll-consult-logo-tooltip">{t('floatingCta.tooltip')}</span>
      </button>
    </main>
    <Footer copy={footerCopy} services={servicesContent.services} />
    <ContactDrawer copy={contactCopy} />
    <script>
      import { initScrollExperience } from '../../components/scroll/scrollExperienceController';
      initScrollExperience();
    </script>
    <script define:vars={{ closeMenuLabel: t('nav.closeMenu'), openMenuLabel: t('nav.openMenu') }}>
      const nav = document.querySelector('.site-nav nav');
      const toggle = document.querySelector('.menu-toggle');
      const drawer = document.querySelector('.contact-drawer');
      const openButtons = Array.from(document.querySelectorAll('[data-contact-trigger]'));
      const closeButtons = Array.from(document.querySelectorAll('[data-contact-close]'));
      const navLinks = Array.from(document.querySelectorAll('[data-nav-close]'));
      const homeLinks = Array.from(document.querySelectorAll('a[href="#inicio"]'));
      const servicesLinks = Array.from(document.querySelectorAll('a[href="#servicios"]'));
      const forms = Array.from(document.querySelectorAll('[data-contact-form]'));
      let contactScrollY = 0;
      let isContactOpen = false;

      const setMenuOpen = (isOpen) => {
        nav?.classList.toggle('is-open', isOpen);
        toggle?.classList.toggle('is-open', isOpen);
        toggle?.setAttribute('aria-expanded', String(isOpen));
        toggle?.setAttribute('aria-label', isOpen ? closeMenuLabel : openMenuLabel);
      };

      const lockBodyScroll = () => {
        contactScrollY = window.scrollY || document.documentElement.scrollTop || 0;
        document.body.style.position = 'fixed';
        document.body.style.top = `-${contactScrollY}px`;
        document.body.style.left = '0';
        document.body.style.right = '0';
        document.body.style.width = '100%';
        document.body.classList.add('drawer-open');
      };

      const unlockBodyScroll = () => {
        document.body.classList.remove('drawer-open');
        document.body.style.position = '';
        document.body.style.top = '';
        document.body.style.left = '';
        document.body.style.right = '';
        document.body.style.width = '';
        window.scrollTo(0, contactScrollY);
      };

      const setContactOpen = (isOpen) => {
        if (!drawer || isOpen === isContactOpen) {
          return;
        }

        isContactOpen = isOpen;
        drawer?.classList.toggle('is-open', isOpen);
        drawer?.setAttribute('aria-hidden', String(!isOpen));

        if (isOpen) {
          lockBodyScroll();
        } else {
          unlockBodyScroll();
        }
      };

      toggle?.addEventListener('click', () => setMenuOpen(!nav?.classList.contains('is-open')));
      navLinks.forEach((link) => link.addEventListener('click', () => setMenuOpen(false)));
      homeLinks.forEach((link) =>
        link.addEventListener('click', (event) => {
          event.preventDefault();
          setMenuOpen(false);
          window.history.pushState(null, '', '#inicio');
          window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
          requestAnimationFrame(() => window.scrollTo({ top: 0, left: 0, behavior: 'auto' }));
        }),
      );
      servicesLinks.forEach((link) =>
        link.addEventListener('click', (event) => {
          const services = document.querySelector('#servicios');

          if (!services) {
            return;
          }

          event.preventDefault();
          setMenuOpen(false);
          window.history.pushState(null, '', '#servicios');
          const navigationEvent = new CustomEvent('agsit:navigate-services', { cancelable: true });
          const wasHandled = !window.dispatchEvent(navigationEvent);

          if (wasHandled) {
            return;
          }

          services.scrollIntoView({ block: 'start', behavior: 'auto' });

          requestAnimationFrame(() => {
            const revealOffset = Math.max(
              560,
              Math.min(window.innerWidth * 0.62, window.innerHeight * 1.05),
            );

            window.scrollTo({
              top: window.scrollY + revealOffset,
              left: 0,
              behavior: 'auto',
            });
          });
        }),
      );
      openButtons.forEach((button) =>
        button.addEventListener('click', () => {
          setMenuOpen(false);
          setContactOpen(true);
        }),
      );
      closeButtons.forEach((button) => button.addEventListener('click', () => setContactOpen(false)));
      forms.forEach((form) => form.addEventListener('submit', (event) => event.preventDefault()));
      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          setContactOpen(false);
        }
      });
      window.addEventListener('agsit:open-contact', () => setContactOpen(true));
      window.addEventListener('agsit:close-contact', () => setContactOpen(false));
    </script>
  </div>
</SiteLayout>
