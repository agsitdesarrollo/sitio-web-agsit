---
import ContactDrawer from '../../components/contact/ContactDrawer.astro';
import DigitalMarketingStoryV2 from '../../components/digital-marketing-v2/DigitalMarketingStoryV2.astro';
import Footer from '../../components/footer/Footer.astro';
import Header from '../../components/navigation/Header.astro';
import PageShellScripts from '../../components/navigation/PageShellScripts.astro';
import { getContactCopy } from '../../data/contact';
import { getDigitalMarketingV2Content } from '../../data/digitalMarketingV2';
import { getFooterCopy } from '../../data/footer';
import { getServicesContent } from '../../data/services';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en';
const content = getDigitalMarketingV2Content(lang);
const contactCopy = getContactCopy(lang);
const footerCopy = getFooterCopy(lang);
const servicesContent = getServicesContent(lang);
const t = useTranslations(lang);
---

<SiteLayout
  title={content.metadata.title}
  description={content.metadata.description}
  canonicalUrl={content.metadata.canonicalUrl}
  htmlLang={content.metadata.htmlLang}
  locale={content.metadata.locale}
  alternates={[
    { lang: 'es-MX', href: 'https://agsit.com.mx/mercadotecnia-digital/' },
    { lang: 'en', href: content.metadata.canonicalUrl },
    { lang: 'x-default', href: 'https://agsit.com.mx/mercadotecnia-digital/' },
  ]}
>
  <div class="app-shell app-shell-dm-v2">
    <Header
      lang={lang}
      homeHref="/en/#inicio"
      servicesHref="/en/#servicios"
      contactHref="#marketing-v2-contact"
      alternateHref="/mercadotecnia-digital/"
    />
    <DigitalMarketingStoryV2 content={content} contactCopy={contactCopy} />
    <Footer
      copy={footerCopy}
      services={servicesContent.services}
      homeHref="/en/#inicio"
      servicesHref="/en/#servicios"
      contactHref="/en/#contacto"
    />
    <ContactDrawer copy={contactCopy} />
    <PageShellScripts openMenuLabel={t('nav.openMenu')} closeMenuLabel={t('nav.closeMenu')} />
  </div>
</SiteLayout>
