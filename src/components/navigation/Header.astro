---
import { Image } from 'astro:assets';
import logoImage from '../../assets/images/logo-asit.webp';
import type { SupportedLang } from '../../i18n/ui';
import { getAlternateLangPath, useTranslations } from '../../i18n/utils';

type Props = {
  lang: SupportedLang;
};

const { lang } = Astro.props;
const t = useTranslations(lang);
const alternateLangPath = getAlternateLangPath(lang);
---

<header class="site-nav">
  <a class="brand" href="#inicio" aria-label={t('nav.brandLabel')} data-nav-close>
    <Image src={logoImage} alt="AGSIT" loading="eager" fetchpriority="high" />
  </a>
  <button
    class="menu-toggle"
    type="button"
    aria-label={t('nav.openMenu')}
    aria-expanded="false"
    aria-controls="main-navigation"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>
  <nav id="main-navigation">
    <a href="#inicio" data-nav-close>{t('nav.home')}</a>
    <a href="#servicios" data-nav-close>{t('nav.services')}</a>
    <a href="#contacto" data-nav-close>{t('nav.contact')}</a>
    <a class="language-switch" href={alternateLangPath} aria-label={t('language.switchLabel')} data-nav-close>
      {t('language.switchText')}
    </a>
  </nav>
</header>
