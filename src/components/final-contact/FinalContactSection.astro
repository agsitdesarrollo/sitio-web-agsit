---
import ContactDirectCard from '../contact/ContactDirectCard.astro';
import ContactForm from '../contact/ContactForm.astro';
---

<section id="contacto" class="final-contact-section" aria-labelledby="final-contact-title">
  <div class="final-contact-content">
    <div class="final-contact-heading">
      <h2 id="final-contact-title">Hablemos de tu siguiente avance.</h2>
      <p>
        Agenda una asesoría sin costo para revisar tus prioridades, detectar oportunidades y definir el siguiente paso
        con claridad.
      </p>
    </div>

    <div class="final-contact-grid">
      <ContactDirectCard />
      <ContactForm />
    </div>
  </div>
</section>
