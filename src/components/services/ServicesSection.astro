---
import { Image } from 'astro:assets';
import type { ServicePoint, ServicesContent } from '../../data/services';
import personImage from '../../assets/images/personaje.webp';

type Props = {
  content: ServicesContent;
};

const { content } = Astro.props;

const iconPath = (icon: ServicePoint['icon']) => {
  if (icon === 'layers') {
    return [
      'M12 3 4 7l8 4 8-4-8-4Z',
      'm4 12 8 4 8-4',
      'm4 17 8 4 8-4',
    ];
  }

  if (icon === 'team') {
    return ['M12 13a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z', 'M4 21a8 8 0 0 1 16 0', 'm9.5 12.5 2 2 4-4'];
  }

  if (icon === 'trend') {
    return ['M4 17 9 12l4 4 7-9', 'M15 7h5v5'];
  }

  return ['M4 4h16v16H4V4Z', 'M12 4v16', 'M4 12h16'];
};
---

<section id="servicios" class="services-scroll js-services" data-services-scroll>
  <div class="services-section services-sticky">
    <div class="services-background" aria-hidden="true"></div>

    <div class="services-intro">
      <h2>{content.introTitle}</h2>
      <p>{content.introSubtitle}</p>
    </div>

    <div class="services-person js-services-person" aria-hidden="true">
      <Image src={personImage} alt="" loading="lazy" />
    </div>

    <div class="services-cards-layer" aria-live="polite">
      {
        content.servicePoints.map((service, index) => {
          const side = index % 2 === 0 ? 'left' : 'right';

          return (
            <article
              class={`service-card ${side}`}
              data-service-card
              data-card-index={index}
              data-card-side={side}
              aria-label={service.title}
            >
              <span class="service-card-icon">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  {iconPath(service.icon).map((path) => (
                    <path d={path} />
                  ))}
                </svg>
              </span>
              <div class="service-card-copy">
                <h3>
                  <span class="copy-desktop">{service.title}</span>
                  <span class="copy-mobile">{service.mobileTitle ?? service.title}</span>
                </h3>
                <p>
                  <span class="copy-desktop">{service.description}</span>
                  <span class="copy-mobile">{service.mobileDescription ?? service.description}</span>
                </p>
              </div>
            </article>
          );
        })
      }
    </div>

    <button class="services-advice-cta" type="button" data-contact-trigger>{content.cta}</button>
  </div>

  <div class="services-snap-track" aria-hidden="true">
    {content.servicePoints.map(() => <div class="services-snap-step"></div>)}
  </div>
</section>

<script>
  const servicesSection = document.querySelector<HTMLElement>('[data-services-scroll]');
  const serviceCards = Array.from(document.querySelectorAll<HTMLElement>('[data-service-card]'));
  const totalCards = serviceCards.length;

  const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);
  const easeOutCubic = (value: number) => 1 - Math.pow(1 - value, 3);
  const easeInCubic = (value: number) => value * value * value;

  const getServicesPanelHeight = () => {
    const navHeight = document.querySelector<HTMLElement>('.site-nav')?.getBoundingClientRect().height ?? 0;
    const isShortLandscape = window.matchMedia(
      '(pointer: coarse) and (orientation: landscape) and (max-width: 932px) and (max-height: 520px)',
    ).matches;
    const viewportVariable = isShortLandscape ? '--app-vh' : '--app-stable-vh';
    const viewportValue = Number.parseFloat(getComputedStyle(document.documentElement).getPropertyValue(viewportVariable));
    const viewportHeight = Number.isFinite(viewportValue) && viewportValue > 0 ? viewportValue : window.innerHeight;

    return Math.max(viewportHeight - navHeight, 1);
  };

  const updateServicesCards = () => {
    if (!servicesSection || totalCards === 0) {
      return;
    }

    const sectionTop = servicesSection.getBoundingClientRect().top;
    const progress = clamp(-sectionTop / getServicesPanelHeight(), 0, totalCards);
    const isMobile = window.matchMedia('(max-width: 640px)').matches;
    const isShortLandscape = window.matchMedia(
      '(pointer: coarse) and (orientation: landscape) and (max-width: 932px) and (max-height: 520px)',
    ).matches;
    const isTablet = window.matchMedia('(min-width: 641px) and (max-width: 1024px)').matches;
    const usesSingleCardLifecycle = isMobile || isShortLandscape;
    const activeSlide = Math.round(progress);

    servicesSection.dataset.activeSlide = String(activeSlide);

    serviceCards.forEach((card, index) => {
      const side = card.dataset.cardSide === 'left' ? -1 : 1;
      const enterProgress = clamp((progress - index - 0.18) / 0.82, 0, 1);
      const enter = easeOutCubic(enterProgress);
      // En portrait y en landscape corto, la tarjeta saliente abandona el
      // encuadre antes de que la siguiente empiece a entrar. Así cada parada
      // conserva una sola tarjeta, incluso cuando cambia la altura útil del
      // navegador móvil.
      const exitStart = index + (usesSingleCardLifecycle ? 1.02 : 1.82);
      const exitDuration = usesSingleCardLifecycle ? 0.16 : 0.18;
      const exitProgress = index < totalCards - 1 ? clamp((progress - exitStart) / exitDuration, 0, 1) : 0;
      const exit = easeInCubic(exitProgress);
      const startX = side * (isShortLandscape ? Math.min(window.innerWidth * 0.38, 280) : isMobile ? 78 : isTablet ? 140 : 340);
      const startY = isShortLandscape ? 24 : isMobile ? 92 : isTablet ? 150 : 310;
      const curveY = startY * Math.pow(1 - enter, 2);
      const opacity = enterProgress === 0 ? 0 : clamp(enter * (1 - exit), 0, 1);

      card.style.setProperty('--service-card-x', `${startX * (1 - enter)}px`);
      card.style.setProperty('--service-card-y', `${curveY}px`);
      card.style.setProperty('--service-card-opacity', String(opacity));
      card.style.setProperty('--service-card-scale', String(0.96 + enter * 0.04));
      card.style.setProperty('--service-card-z', String(10 + index));
      card.classList.toggle('is-current', activeSlide === index + 1);
    });
  };

  window.addEventListener('scroll', updateServicesCards, { passive: true });
  window.addEventListener('resize', updateServicesCards, { passive: true });
  window.addEventListener('agsit:viewport-change', updateServicesCards, { passive: true });
  updateServicesCards();
</script>
