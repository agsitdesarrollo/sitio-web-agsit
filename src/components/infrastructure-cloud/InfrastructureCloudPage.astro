---
import FinalContactSection from '../final-contact/FinalContactSection.astro';
import ServicePageAnimations from '../service-animation/ServicePageAnimations.astro';
import type { ContactCopy } from '../../data/contact';
import type { InfrastructureCloudContent } from '../../data/infrastructureCloud';

type Props = {
  content: InfrastructureCloudContent;
  contactCopy: ContactCopy;
};

const { content, contactCopy } = Astro.props;
---

<main class="ops-page">
  <section class="ops-hero" aria-labelledby="ops-hero-title">
    <video class="ops-hero-video" aria-hidden="true" autoplay muted loop playsinline preload="metadata">
      <source src="/assets/binary-wave-bg.webm" type="video/webm" />
      <source src="/assets/binary-wave-bg.mp4" type="video/mp4" />
    </video>

    <div class="ops-hero-content">
      <p class="ops-eyebrow">{content.hero.eyebrow}</p>
      <h1 id="ops-hero-title">{content.hero.title}</h1>
      <p>{content.hero.copy}</p>
      <div class="ops-actions">
        <button type="button" data-contact-trigger>{content.hero.primaryCta}</button>
      </div>
    </div>
  </section>

  <section class="ops-method" aria-labelledby="ops-method-title">
    <div class="ops-section-heading">
      <p class="ops-eyebrow">{content.challenges.eyebrow}</p>
      <h2 id="ops-method-title">{content.challenges.title}</h2>
      <p>{content.challenges.copy}</p>
    </div>

    <div class="ops-method-map" data-no-reveal>
      <div class="ops-method-path" aria-hidden="true">
        <span></span>
        <span></span>
      </div>
      {content.challenges.items.map((item, index) => (
        <article class={`ops-method-step ops-method-step-${index + 1}`}>
          <span class="ops-step-index">{String(index + 1).padStart(2, '0')}</span>
          <div class="ops-step-node" aria-hidden="true">
            <span></span>
          </div>
          <p class="ops-step-label">{item.label}</p>
          <h3>{item.title}</h3>
          <p>{item.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="servicios-incluidos" class="ops-services" aria-labelledby="ops-services-title">
    <div class="ops-section-heading">
      <p class="ops-eyebrow">{content.services.eyebrow}</p>
      <h2 id="ops-services-title">{content.services.title}</h2>
      <p>{content.services.copy}</p>
    </div>

    <div class="ops-service-grid" data-no-reveal>
      {content.services.items.map((item) => (
        <article class="ops-service-card" tabindex="0" aria-label={item.title}>
          <div class="ops-service-card-inner">
            <div class="ops-service-card-front">
              <span class="ops-service-code">{item.code}</span>
              <h3>{item.title}</h3>
              <p>{item.copy}</p>
            </div>
            <div class="ops-service-card-back" aria-hidden="true">
              <p class="ops-service-back-label">{content.services.activitiesLabel}</p>
              <ul class="ops-service-activities">
                {item.activities.map((activity) => <li>{activity}</li>)}
              </ul>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="ops-benefits" aria-labelledby="ops-benefits-title">
    <div class="ops-section-heading">
      <p class="ops-eyebrow">{content.benefits.eyebrow}</p>
      <h2 id="ops-benefits-title">{content.benefits.title}</h2>
      <p>{content.benefits.copy}</p>
    </div>

    <div class="ops-benefit-grid">
      {content.benefits.items.map((benefit) => (
        <article class="ops-benefit-card">
          <span>{benefit.value}</span>
          <h3>{benefit.title}</h3>
          <p>{benefit.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="ops-approach" aria-labelledby="ops-approach-title">
    <div class="ops-section-heading">
      <p class="ops-eyebrow">{content.approach.eyebrow}</p>
      <h2 id="ops-approach-title">{content.approach.title}</h2>
      <p>{content.approach.copy}</p>
    </div>

    <div class="ops-approach-map">
      <div class="ops-approach-path" aria-hidden="true"></div>
      {content.approach.steps.map((step, index) => (
        <article class={`ops-approach-step ops-approach-step-${index + 1}`}>
          <span class="ops-step-index">{step.label}</span>
          <div class="ops-step-node" aria-hidden="true">
            <span></span>
          </div>
          <h3>{step.title}</h3>
          <p>{step.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <FinalContactSection copy={contactCopy} />

  <ServicePageAnimations />
</main>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const getOpsNavOffset = () => {
    const nav = document.querySelector('.site-nav, .site-header, header');
    return nav instanceof HTMLElement ? Math.round(nav.getBoundingClientRect().height) : 0;
  };

  const getOpsViewportHeight = () => {
    const stableVh = Number.parseFloat(
      getComputedStyle(document.documentElement).getPropertyValue('--app-stable-vh'),
    );
    return Number.isFinite(stableVh) && stableVh > 0 ? stableVh : window.innerHeight;
  };

  const setupOpsMethodScroll = () => {
    const root = document.querySelector('.ops-page');
    if (!root || root.hasAttribute('data-ops-method-ready')) return;

    const method = root.querySelector('.ops-method');
    const steps = gsap.utils.toArray<HTMLElement>('.ops-method-step', method);

    if (!(method instanceof HTMLElement) || steps.length === 0) return;

    root.setAttribute('data-ops-method-ready', 'true');

    const matchMedia = gsap.matchMedia();
    const getSequenceEnd = (multiplier: number) =>
      `+=${Math.round(getOpsViewportHeight() * multiplier)}`;
    const getPinStart = () => `top top+=${getOpsNavOffset()}`;

    matchMedia.add('(prefers-reduced-motion: no-preference) and (min-width: 680px) and (min-height: 521px)', () => {
      method.classList.add('is-scroll-sequence');
      gsap.set(steps, { autoAlpha: 0, y: 56 });

      const timeline = gsap.timeline({
        defaults: { ease: 'none' },
        scrollTrigger: {
          id: 'ops-method-sequence-desktop',
          trigger: method,
          start: getPinStart,
          end: () => getSequenceEnd(steps.length * 0.72),
          pin: true,
          pinSpacing: true,
          scrub: 0.65,
          anticipatePin: 1,
          invalidateOnRefresh: true,
        },
      });

      steps.forEach((step) => {
        timeline
          .to(step, { autoAlpha: 1, y: 0, duration: 1, ease: 'power2.out' })
          .to({}, { duration: 0.22 });
      });

      return () => {
        timeline.kill();
        method.classList.remove('is-scroll-sequence');
        gsap.set(steps, { clearProps: 'all' });
      };
    });

    matchMedia.add('(prefers-reduced-motion: no-preference) and (max-width: 679px)', () => {
      method.classList.add('is-scroll-sequence', 'is-mobile-sequence');
      gsap.set(steps, { autoAlpha: 0, y: 46 });

      const timeline = gsap.timeline({
        defaults: { ease: 'none' },
        scrollTrigger: {
          id: 'ops-method-sequence-mobile',
          trigger: method,
          start: getPinStart,
          end: () => getSequenceEnd(steps.length * 0.86),
          pin: true,
          pinSpacing: true,
          scrub: 0.7,
          anticipatePin: 1,
          invalidateOnRefresh: true,
        },
      });

      timeline
        .to(steps[0], { autoAlpha: 1, y: 0, duration: 0.78, ease: 'power2.out' })
        .to({}, { duration: 0.34 });

      steps.slice(1).forEach((step, index) => {
        const previousStep = steps[index];
        const isLastStep = index === steps.length - 2;
        const label = `ops-step-${index + 2}`;

        timeline
          .add(label)
          .to(previousStep, { autoAlpha: 0, y: -22, duration: 0.5, ease: 'power1.in' }, label)
          .fromTo(
            step,
            { autoAlpha: 0, y: 46 },
            { autoAlpha: 1, y: 0, duration: 0.78, ease: 'power2.out' },
            label,
          )
          .to({}, { duration: isLastStep ? 0.62 : 0.32 });
      });

      return () => {
        timeline.kill();
        method.classList.remove('is-scroll-sequence', 'is-mobile-sequence');
        gsap.set(steps, { clearProps: 'all' });
      };
    });

    window.addEventListener('agsit:viewport-change', () => ScrollTrigger.refresh());
  };

  const setupOpsFlipCards = () => {
    const cards = document.querySelectorAll<HTMLElement>('.ops-service-card');
    if (cards.length === 0) return;
    const isTouch = window.matchMedia('(hover: none)').matches;
    cards.forEach((card) => {
      if (isTouch) {
        card.addEventListener('click', () => card.classList.toggle('is-flipped'));
      }
      card.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          card.classList.toggle('is-flipped');
        }
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setupOpsFlipCards();
      setupOpsMethodScroll();
    }, { once: true });
  } else {
    setupOpsFlipCards();
    setupOpsMethodScroll();
  }
</script>
