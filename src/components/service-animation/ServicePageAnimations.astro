<script>
  const setupServicePageAnimations = () => {
    const root = document.querySelector(
      '.technology-page, .itg-page, .process-page, .project-page, .quality-page, .crm-page, .digital-page',
    );

    if (!root || root.hasAttribute('data-service-animations-ready')) return;

    root.setAttribute('data-service-animations-ready', 'true');

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealSelectors = [
      'section > [class*="-section-heading"]',
      'section > [class*="-hero-copy"]',
      'section > [class*="-hero-content"]',
      'section > [class*="-copy"]',
      'section > [class*="-heading"]',
      'section > h2',
      'article',
      'li',
      '[class*="-map"]',
      '[class*="-board"]',
      '[class*="-seal"]',
      '[class*="-orbit"]',
      '[class*="-hub"]',
      '[class*="-video-panel"]',
      '[class*="-contact-grid"]',
    ];

    const revealItems = Array.from(root.querySelectorAll(revealSelectors.join(','))).filter((item) => {
      return item instanceof HTMLElement && !item.closest('[data-contact-drawer]') && !item.closest('[data-no-reveal]');
    });

    revealItems.forEach((item, index) => {
      item.setAttribute('data-service-reveal', '');
      item.style.setProperty('--service-reveal-delay', `${Math.min(index % 8, 7) * 55}ms`);
    });

    if (reduceMotion || !('IntersectionObserver' in window)) {
      revealItems.forEach((item) => item.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      {
        rootMargin: '0px 0px -12% 0px',
        threshold: 0.12,
      },
    );

    revealItems.forEach((item) => observer.observe(item));
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupServicePageAnimations, { once: true });
  } else {
    setupServicePageAnimations();
  }
</script>
