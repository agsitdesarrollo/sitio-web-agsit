---
import ContactDirectCard from './ContactDirectCard.astro';
import ContactForm from './ContactForm.astro';
import type { ContactCopy } from '../../data/contact';

type Props = {
  eyebrow: string;
  title: string;
  copy: string;
  contactCopy: ContactCopy;
  id?: string;
  headingClass?: string;
};

const { eyebrow, title, copy, contactCopy, id, headingClass } = Astro.props;
const headingId = id ? `${id}-title` : 'service-contact-title';
---

<section id={id} class="svc-contact" aria-labelledby={headingId}>
  <div class:list={['svc-contact-heading', headingClass]}>
    <p class="svc-contact-eyebrow">{eyebrow}</p>
    <h2 id={headingId}>{title}</h2>
    <p>{copy}</p>
  </div>
  <div class="svc-contact-grid">
    <ContactDirectCard copy={contactCopy.direct} />
    <div class="svc-contact-form">
      <ContactForm copy={contactCopy.form} />
    </div>
  </div>
</section>
