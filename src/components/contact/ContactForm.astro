---
import type { ContactFormCopy } from '../../data/contact';

type Props = {
  copy: ContactFormCopy;
};

const { copy } = Astro.props;
---

<form class="contact-form" data-contact-form>
  <label>
    {copy.name}
    <input type="text" name="name" placeholder={copy.namePlaceholder} />
  </label>
  <label>
    {copy.lastName}
    <input type="text" name="lastName" placeholder={copy.lastNamePlaceholder} />
  </label>
  <label>
    {copy.phone}
    <input type="tel" name="phone" placeholder={copy.phonePlaceholder} />
  </label>
  <label>
    {copy.email}
    <input type="email" name="email" placeholder={copy.emailPlaceholder} />
  </label>
  <label class="contact-form-wide">
    {copy.company}
    <input type="text" name="company" placeholder={copy.companyPlaceholder} />
  </label>
  <label class="contact-form-wide">
    {copy.message}
    <textarea name="message" placeholder={copy.messagePlaceholder} rows="4"></textarea>
  </label>
  <button class="contact-submit" type="submit">{copy.submit}</button>
</form>
