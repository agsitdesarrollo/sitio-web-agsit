<form class="contact-form" data-contact-form>
  <label>
    Nombre
    <input type="text" name="name" placeholder="Tu nombre" />
  </label>
  <label>
    Apellido
    <input type="text" name="lastName" placeholder="Tu apellido" />
  </label>
  <label>
    Teléfono
    <input type="tel" name="phone" placeholder="+52" />
  </label>
  <label>
    Email
    <input type="email" name="email" placeholder="correo@empresa.com" />
  </label>
  <label class="contact-form-wide">
    Nombre de la compañía
    <input type="text" name="company" placeholder="Empresa" />
  </label>
  <label class="contact-form-wide">
    Comentario
    <textarea name="message" placeholder="Describe brevemente el proyecto o necesidad" rows="4"></textarea>
  </label>
  <button class="contact-submit" type="submit">Solicitar asesoría</button>
</form>
