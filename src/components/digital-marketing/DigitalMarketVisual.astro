---
import type { MarketingKpi, MarketingSceneVisual } from '../../data/digitalMarketing';
import MetricDashboard from './MetricDashboard.astro';

type Props = {
  variant: MarketingSceneVisual;
  terms?: string[];
  kpis?: MarketingKpi[];
};

const { variant, terms = [], kpis = [] } = Astro.props;

const nodes = [
  { x: 17, y: 24, size: 'sm' },
  { x: 34, y: 39, size: 'md' },
  { x: 54, y: 23, size: 'sm' },
  { x: 70, y: 47, size: 'lg' },
  { x: 24, y: 68, size: 'md' },
  { x: 48, y: 74, size: 'sm' },
  { x: 78, y: 72, size: 'md' },
];
---

<div class:list={['digital-market-visual js-digital-visual', `digital-market-visual-${variant}`]}>
  <div class="market-visual-surface">
    <svg class="market-network" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true" focusable="false">
      <path class="network-line line-1" d="M17 24 C28 24 24 40 34 39 S45 25 54 23 S62 42 70 47" />
      <path class="network-line line-2" d="M34 39 C28 52 28 60 24 68 S38 76 48 74 S66 66 78 72" />
      <path class="network-line line-3" d="M54 23 C58 42 62 52 70 47 S78 60 78 72" />
      <path class="network-line line-4" d="M17 24 C18 44 20 58 24 68" />
    </svg>

    <div class="market-node-layer" aria-hidden="true">
      {
        nodes.map((node, index) => (
          <span
            class:list={[
              'market-node js-market-node',
              `market-node-${node.size}`,
              { 'is-opportunity': variant === 'opportunity' && [1, 3, 6].includes(index) },
            ]}
            style={`--node-x: ${node.x}%; --node-y: ${node.y}%; --node-delay: ${index * 80}ms`}
          ></span>
        ))
      }
    </div>

    {
      variant !== 'control' && (
        <div class="market-term-layer" aria-hidden="true">
          {terms.map((term, index) => (
            <span class={`market-term market-term-${index + 1}`}>{term}</span>
          ))}
        </div>
      )
    }

    {
      variant === 'noise' && (
        <div class="noise-metrics" aria-hidden="true">
          {kpis.map((metric, index) => (
            <article class={`noise-card noise-card-${index + 1}`}>
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </article>
          ))}
        </div>
      )
    }

    {
      variant === 'control' && (
        <div class="visual-dashboard-wrap">
          <MetricDashboard metrics={kpis} compact />
        </div>
      )
    }
  </div>
</div>
