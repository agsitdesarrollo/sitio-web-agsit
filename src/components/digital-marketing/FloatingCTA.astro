---
type Props = {
  label: string;
  href: string;
};

const { label, href } = Astro.props;
---

<a class="marketing-floating-cta js-marketing-floating-cta" href={href}>
  <span>{label}</span>
  <svg viewBox="0 0 18 18" aria-hidden="true" focusable="false">
    <path d="M4 9h9" />
    <path d="m9.5 4.5 4.5 4.5-4.5 4.5" />
  </svg>
</a>
