---
import ContactDirectCard from '../contact/ContactDirectCard.astro';
import ContactForm from '../contact/ContactForm.astro';
import type { ContactCopy } from '../../data/contact';
import type { DigitalMarketingContent } from '../../data/digitalMarketing';
import FloatingCTA from './FloatingCTA.astro';
import HorizontalProcess from './HorizontalProcess.astro';
import MarketingStory from './MarketingStory.astro';
import MetricDashboard from './MetricDashboard.astro';

type Props = {
  content: DigitalMarketingContent;
  contactCopy: ContactCopy;
};

const { content, contactCopy } = Astro.props;
---

<main class="digital-page js-digital-page">
  <FloatingCTA label={content.floatingCta.label} href="#marketing-contact" />

  <MarketingStory scenes={content.scenes} />

  <HorizontalProcess
    eyebrow={content.process.eyebrow}
    title={content.process.title}
    copy={content.process.copy}
    stations={content.process.stations}
  />

  <section class="marketing-results" aria-labelledby="marketing-results-title">
    <div class="marketing-results-copy js-marketing-reveal">
      <p class="digital-eyebrow">{content.results.eyebrow}</p>
      <h2 id="marketing-results-title">{content.results.title}</h2>
      <p>{content.results.copy}</p>
    </div>
    <div class="marketing-results-panel js-marketing-reveal">
      <MetricDashboard metrics={content.results.metrics} />
    </div>
  </section>

  <section class="marketing-capabilities" aria-labelledby="marketing-capabilities-title">
    <div class="marketing-capabilities-heading js-marketing-reveal">
      <p class="digital-eyebrow">{content.capabilities.eyebrow}</p>
      <h2 id="marketing-capabilities-title">{content.capabilities.title}</h2>
      <p>{content.capabilities.copy}</p>
    </div>
    <div class="marketing-capability-grid">
      {
        content.capabilities.items.map((item) => (
          <article class="marketing-capability js-marketing-reveal">
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="marketing-contact" class="marketing-contact" aria-labelledby="marketing-contact-title">
    <div class="marketing-contact-heading js-marketing-reveal">
      <p class="digital-eyebrow">{content.cta.eyebrow}</p>
      <h2 id="marketing-contact-title">{content.cta.title}</h2>
      <p>{content.cta.copy}</p>
    </div>
    <div class="marketing-contact-grid">
      <ContactDirectCard copy={contactCopy.direct} />
      <div class="marketing-contact-form">
        <ContactForm copy={contactCopy.form} />
      </div>
    </div>
  </section>
</main>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initDigitalMarketingStory = () => {
    const root = document.querySelector<HTMLElement>('.js-digital-page');

    if (!root || root.dataset.marketingStoryReady === 'true') {
      return;
    }

    root.dataset.marketingStoryReady = 'true';

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealItems = gsap.utils.toArray<HTMLElement>('.js-marketing-reveal', root);
    const storyCopies = gsap.utils.toArray<HTMLElement>('.js-story-copy', root);
    const floatingCta = root.querySelector<HTMLElement>('.js-marketing-floating-cta');

    if (reduceMotion) {
      root.classList.add('is-reduced-motion');
      revealItems.forEach((item) => item.classList.add('is-visible'));
      storyCopies.forEach((item) => item.classList.add('is-visible'));
      floatingCta?.classList.add('is-visible');
      return;
    }

    const getNavHeight = () => document.querySelector<HTMLElement>('.site-nav')?.getBoundingClientRect().height ?? 0;
    const getPinnedStart = () => `top top+=${getNavHeight()}`;
    const context = gsap.context(() => {
      ScrollTrigger.config({ ignoreMobileResize: true });

      gsap.set(revealItems, { autoAlpha: 0, y: 24 });

      gsap.utils.toArray<HTMLElement>('.js-story-scene', root).forEach((scene) => {
        const copyItems = scene.querySelectorAll<HTMLElement>('.js-story-copy > *');
        const nodes = scene.querySelectorAll<HTMLElement>('.js-market-node');
        const terms = scene.querySelectorAll<HTMLElement>('.market-term');
        const lines = scene.querySelectorAll<SVGPathElement>('.network-line');
        const cards = scene.querySelectorAll<HTMLElement>('.noise-card, .metric-dashboard-grid article');

        gsap.set(copyItems, { autoAlpha: 0, y: 28 });
        gsap.set(nodes, { scale: 0.72, autoAlpha: 0 });
        if (terms.length) {
          gsap.set(terms, { autoAlpha: 0, y: 16 });
        }
        if (cards.length) {
          gsap.set(cards, { autoAlpha: 0, y: 18 });
        }

        // Story scenes keep one protagonist visual while the surrounding signal field transforms.
        const sceneTimeline = gsap.timeline({
          scrollTrigger: {
            trigger: scene,
            start: () => `top 72%`,
            end: () => `bottom 42%`,
            scrub: 0.8,
            invalidateOnRefresh: true,
          },
        });

        sceneTimeline
          .to(copyItems, { autoAlpha: 1, y: 0, duration: 0.34, stagger: 0.06, ease: 'power2.out' }, 0.04)
          .to(lines, { strokeDashoffset: 0, duration: 0.72, stagger: 0.08, ease: 'none' }, 0)
          .to(nodes, { autoAlpha: 1, scale: 1, duration: 0.38, stagger: 0.05, ease: 'power2.out' }, 0.08);

        if (terms.length) {
          sceneTimeline.to(terms, { autoAlpha: 1, y: 0, duration: 0.34, stagger: 0.04, ease: 'power2.out' }, 0.18);
        }

        if (cards.length) {
          sceneTimeline.to(cards, { autoAlpha: 1, y: 0, duration: 0.34, stagger: 0.06, ease: 'power2.out' }, 0.22);
        }

        gsap.to(scene.querySelectorAll<HTMLElement>('.js-digital-visual'), {
          yPercent: -5,
          ease: 'none',
          scrollTrigger: {
            trigger: scene,
            start: 'top bottom',
            end: 'bottom top',
            scrub: true,
          },
        });
      });

      ScrollTrigger.batch(gsap.utils.toArray<HTMLElement>('.js-marketing-reveal', root), {
        start: 'top 82%',
        once: true,
        onEnter: (batch) => {
          gsap.to(batch, {
            autoAlpha: 1,
            y: 0,
            duration: 0.58,
            stagger: 0.08,
            ease: 'power2.out',
            overwrite: true,
          });
        },
      });

      const process = root.querySelector<HTMLElement>('.js-marketing-process');
      const processPin = root.querySelector<HTMLElement>('.js-process-pin');
      const processTrack = root.querySelector<HTMLElement>('.js-process-track');
      const processStations = gsap.utils.toArray<HTMLElement>('.js-process-station', root);
      const matchMedia = gsap.matchMedia();

      matchMedia.add('(min-width: 901px)', () => {
        if (!process || !processPin || !processTrack || processStations.length < 2) {
          return undefined;
        }

        gsap.set(processStations, { autoAlpha: 0.42, scale: 0.94 });

        // Desktop uses vertical scroll to drive a pinned horizontal process.
        const horizontalTween = gsap.to(processTrack, {
          x: () => -(processTrack.scrollWidth - processPin.clientWidth),
          ease: 'none',
          scrollTrigger: {
            trigger: process,
            start: getPinnedStart,
            end: () => `+=${Math.max(window.innerHeight * 2.9, processStations.length * 520)}`,
            scrub: 1,
            pin: processPin,
            anticipatePin: 1,
            invalidateOnRefresh: true,
          },
        });

        processStations.forEach((station) => {
          gsap.to(station, {
            autoAlpha: 1,
            scale: 1,
            ease: 'none',
            scrollTrigger: {
              trigger: station,
              containerAnimation: horizontalTween,
              start: 'left 72%',
              end: 'right 42%',
              scrub: true,
            },
          });

          gsap.fromTo(
            station.querySelectorAll<HTMLElement>('.process-visual-primary span, .process-visual-flow i'),
            { autoAlpha: 0, y: 18 },
            {
              autoAlpha: 1,
              y: 0,
              stagger: 0.04,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: station,
                containerAnimation: horizontalTween,
                start: 'left 64%',
                end: 'center center',
                scrub: 0.6,
              },
            },
          );
        });

        return () => {
          gsap.set(processTrack, { clearProps: 'transform' });
          gsap.set(processStations, { clearProps: 'opacity,visibility,transform' });
        };
      });

      matchMedia.add('(max-width: 900px)', () => {
        processStations.forEach((station) => {
          gsap.fromTo(
            station,
            { autoAlpha: 0, y: 30 },
            {
              autoAlpha: 1,
              y: 0,
              duration: 0.58,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: station,
                start: 'top 82%',
                once: true,
              },
            },
          );
        });

        return undefined;
      });

      if (floatingCta) {
        ScrollTrigger.create({
          trigger: '.js-story-trigger-cta',
          start: 'top 70%',
          onEnter: () => floatingCta.classList.add('is-visible'),
          onLeaveBack: () => floatingCta.classList.remove('is-visible'),
        });

        ScrollTrigger.create({
          trigger: '#marketing-contact',
          start: 'top 78%',
          onEnter: () => floatingCta.classList.remove('is-visible'),
          onLeaveBack: () => floatingCta.classList.add('is-visible'),
        });
      }

      const refresh = () => ScrollTrigger.refresh();
      window.addEventListener('agsit:viewport-change', refresh, { passive: true });
      window.addEventListener('orientationchange', refresh, { passive: true });

      return () => {
        window.removeEventListener('agsit:viewport-change', refresh);
        window.removeEventListener('orientationchange', refresh);
        matchMedia.revert();
      };
    }, root);

    window.addEventListener('pagehide', () => context.revert(), { once: true });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDigitalMarketingStory, { once: true });
  } else {
    initDigitalMarketingStory();
  }
</script>
