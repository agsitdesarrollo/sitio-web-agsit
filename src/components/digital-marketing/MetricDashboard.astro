---
import type { MarketingKpi } from '../../data/digitalMarketing';

type Props = {
  metrics: MarketingKpi[];
  compact?: boolean;
};

const { metrics, compact = false } = Astro.props;
---

<div class:list={['metric-dashboard js-metric-dashboard', { 'metric-dashboard-compact': compact }]} aria-hidden="true">
  <div class="metric-dashboard-top">
    <span>AGSIT</span>
    <span>Marketing control</span>
  </div>
  <div class="metric-dashboard-chart">
    <span class="chart-grid-line"></span>
    <span class="chart-grid-line"></span>
    <span class="chart-grid-line"></span>
    <svg viewBox="0 0 520 210" role="img" aria-label="">
      <path class="dashboard-area" d="M18 180 C74 146 96 164 142 118 C189 70 232 112 276 80 C330 40 370 78 420 46 C456 23 484 26 504 18 L504 204 L18 204 Z" />
      <path class="dashboard-line" d="M18 180 C74 146 96 164 142 118 C189 70 232 112 276 80 C330 40 370 78 420 46 C456 23 484 26 504 18" />
      <circle class="dashboard-dot dashboard-dot-1" cx="142" cy="118" r="7" />
      <circle class="dashboard-dot dashboard-dot-2" cx="276" cy="80" r="7" />
      <circle class="dashboard-dot dashboard-dot-3" cx="420" cy="46" r="7" />
    </svg>
  </div>
  <div class="metric-dashboard-grid">
    {
      metrics.map((metric) => (
        <article>
          <strong>{metric.value}</strong>
          <span>{metric.label}</span>
        </article>
      ))
    }
  </div>
</div>
