---
import type { AboutContent } from '../../data/about';
import { clientLogos } from '../../data/about';

type Props = {
  content: AboutContent;
};

const { content } = Astro.props;
const aboutScrollSteps = Array.from({ length: 9 });
// La rejilla de clientes muestra 15 lugares; el resto del array es la reserva
// que entra en rotación (ver el bloque de rotación en el script de abajo).
const VISIBLE_CLIENT_LOGOS = 15;
const visibleClientLogos = clientLogos.slice(0, VISIBLE_CLIENT_LOGOS);

// side per service index (0-based): even = texto-right/video-left, odd = texto-left/video-right
// const serviceSides = content.services.map((_, i) => (i % 2 === 0 ? 'text-right' : 'text-left'));
const getVideoAspectRatio = (image: string) => (image.endsWith('/servicios.mp4') ? '1 / 1' : '16 / 9');
const getVideoRatioKind = (image: string) => (image.endsWith('/servicios.mp4') ? 'square' : 'wide');
---

<section
  id="experiencia"
  class="about-snap-section js-about-snap"
  aria-label={content.sectionLabel}
>
  <div class="about-snap-viewport">
  <div class="about-snap-stage">

    <!-- Slide 0: Intro -->
    <div class="about-snap-slide about-snap-slide--intro is-active" data-slide="0">
      <div class="about-overview">
        <p class="about-overview-kicker">{content.overview.kicker}</p>
        <h2 class="about-overview-title">
          {content.overview.title}
          <span>{content.overview.titleAccent}</span>
        </h2>
        <p class="about-overview-copy">{content.overview.copy}</p>
        <p class="about-overview-scroll">{content.overview.scroll}</p>
      </div>
    </div>

    <!-- Slides 1-5: Services -->
    {
      content.services.map((service, i) => (
        <div class="about-snap-slide about-snap-slide--service" data-slide={i + 1}>
          <article
            class="about-service-story js-about-service-card"
            
            data-service-code={service.code}
            aria-label={service.alt}
          >
            <div
              class="about-service-image-frame js-about-service-visual"
              data-video-ratio={getVideoRatioKind(service.image)}
              style={`--about-service-video-ratio: ${getVideoAspectRatio(service.image)}`}
            >
              <video
                data-src={service.image}
                poster={service.poster}
                muted
                loop
                playsinline
                preload="metadata"
              />
            </div>
            <div class="about-service-body js-about-service-body">
              <p class="about-service-number" aria-hidden="true">{service.number}</p>
              <p class="about-service-code">
                {service.code} – {service.label}
              </p>
              <h3>{service.title}</h3>
              <p class="about-service-description">{service.description}</p>
              <div class="about-service-tags">
                {service.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
              {service.href ? (
                <a class="about-service-link" href={service.href}>
                  {content.serviceLinkLabel} {service.code} →
                </a>
              ) : (
                <p class="about-service-link">
                  {content.serviceLinkLabel} {service.code} →
                </p>
              )}
            </div>
          </article>
        </div>
      ))
    }

    <!-- Slide 6: Clients -->
    <div class="about-snap-slide about-snap-slide--clients" data-slide="6">
      <div class="about-clients-copy js-about-clients-copy">
        <h2>{content.clients.title}</h2>
        <p>{content.clients.copy}</p>
      </div>
      <div class="about-clients-stage js-about-clients-stage">
        <div class="about-clients-logo-grid" aria-label={content.clients.title}>
          {visibleClientLogos.map((client) => (
            <div class="about-client-logo js-about-client-logo">
              <img
                src={client.src}
                alt={`Logo cliente AGSIT ${client.label}`}
                loading="eager"
                decoding="async"
                draggable="false"
              />
            </div>
          ))}
        </div>
        <script type="application/json" class="js-client-logo-pool" set:html={JSON.stringify(clientLogos)} />
      </div>
    </div>

    <!-- Slide 7: Alliance -->
    <div class="about-snap-slide about-snap-slide--alliance" data-slide="7">
      <div class="about-transition-veil js-about-transition-veil" aria-hidden="true"></div>
      <div class="about-alliance-layout">
        <div class="about-alliance-copy js-about-alliance-copy">
          <h2
            class="about-alliance-title"
            aria-label={content.alliance.titleLabel}
          >
            {content.alliance.titleLines.map((line) => (
              <span class="about-alliance-title-line">{line}</span>
            ))}
          </h2>
          <p>{content.alliance.copy}</p>
        </div>
        <div
          class="about-transition-logo js-about-transition-logo"
          aria-hidden="true"
        >
          <img
            class="about-transition-logo-image"
            src="/assets/logo-agsit.svg"
            alt=""
            loading="lazy"
            draggable="false"
          />
        </div>
        <div class="about-alliance-triangle-wrap" aria-hidden="true">
          <span class="about-alliance-metric about-alliance-metric-scope js-about-alliance-metric">
            {content.alliance.metrics.scope}
          </span>
          <div class="about-alliance-triangle-spacer"></div>
          <div class="about-alliance-triangle-bottom">
            <span class="about-alliance-metric about-alliance-metric-cost js-about-alliance-metric pl-9">
              {content.alliance.metrics.cost}
            </span>
            <span class="about-alliance-metric about-alliance-metric-time js-about-alliance-metric max-sm:pr-8">
              {content.alliance.metrics.time}
            </span>
          </div>
        </div>
        <button
          class="about-alliance-cta js-about-alliance-cta"
          type="button"
          data-contact-trigger
        >
          {content.alliance.cta}
        </button>
      </div>
    </div>

  </div><!-- /about-snap-stage -->

  <!-- Bottom bar: always visible -->
  <div class="about-snap-bar js-about-snap-bar" aria-hidden="true">
    <div class="about-snap-bar-dots-wrap">
      <div class="about-snap-bar-line"></div>
      <div class="about-snap-bar-progress js-bar-progress"></div>
      {
        content.services.map((_, i) => (
          <div class="about-snap-dot js-about-snap-dot" data-dot={i}>
            <span class="about-snap-dot-number">{i + 1}</span>
          </div>
        ))
      }
    </div>
  </div>
  </div>

  <div class="about-snap-track" aria-hidden="true">
    {aboutScrollSteps.map(() => <div class="about-snap-step"></div>)}
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ALLIANCE_LOGO_OVERSAMPLE, initAllianceLogoZoom } from '../../animations/allianceLogoZoom';
  import { getAllianceVideoHandoff } from '../scroll/allianceVideoHandoff';
  import { ensureVideoAutoplay } from '../../scripts/videoAutoplay';
  // ── Constants ─────────────────────────────────────────────────────────────
  const TOTAL_SLIDES = 8;
  const LAST_SERVICE_SLIDE = 5;
  const CLIENTS_SLIDE = 6;
  const ALLIANCE_SLIDE = 7;
  const ANIM_MS = 900;

  // % left for each service dot inside the dots-wrap
  const DOT_LEFTS = [7.5, 21, 34.5, 48, 61.5];
  // % left for clients/alliance logo position (relative to viewport)
  const CLIENTS_LOGO_PCT_MOBILE = 72;
  const CLIENTS_LOGO_PCT_TABLET = 78;
  const CLIENTS_LOGO_PCT_DESKTOP = 82;
  const SLIDE_POSITIONS = [
    { x: 0, y: 0 },
    { x: 1, y: 1 },
    { x: 2, y: 0 },
    { x: 3, y: 1 },
    { x: 4, y: 0 },
    { x: 5, y: 1 },
    { x: 5, y: 2 },
    { x: 6, y: 2 },
  ] as const;

  // ── DOM ───────────────────────────────────────────────────────────────────
  const section = document.querySelector<HTMLElement>('.js-about-snap');
  if (!section) throw new Error('AboutSnap: section not found');
  const handoff = getAllianceVideoHandoff();

  const stage = section.querySelector<HTMLElement>('.about-snap-stage');
  const slides = Array.from(section.querySelectorAll<HTMLElement>('.about-snap-slide'));
  const dots   = Array.from(section.querySelectorAll<HTMLElement>('.js-about-snap-dot'));
  const bar    = section.querySelector<HTMLElement>('.js-about-snap-bar');
  const progressEl = section.querySelector<HTMLElement>('.js-bar-progress');

  if (!stage) {
    throw new Error('AboutSnap: stage not found');
  }

  if (slides.length !== TOTAL_SLIDES) {
    throw new Error(`AboutSnap: expected ${TOTAL_SLIDES} slides, got ${slides.length}`);
  }

  // ── State ─────────────────────────────────────────────────────────────────
  let current = 0;
  let isAnimating = false;
  let isActive = false;
  let allianceDone = false;
  let alliancePlayed = false;
  let allianceScrubTl: gsap.core.Timeline | undefined;
  let allianceScrubTween: gsap.core.Tween | undefined;
  let forwardHandoffTimeout = 0;
  let allianceScrubTime = 0;
  let isAllianceScrubbing = false;

  // ── Breakpoints ───────────────────────────────────────────────────────────
  // En sincronía con los cortes de AboutHorizontal.css (tablet desde 600px).
  const isMobile = () => window.matchMedia('(max-width: 599px)').matches;
  const isTablet = () => window.matchMedia('(min-width: 600px) and (max-width: 1024px)').matches;
  const isShortLandscape = () => window.matchMedia(
    '(pointer: coarse) and (orientation: landscape) and (max-width: 932px) and (max-height: 520px)',
  ).matches;
  const getNavH  = () => document.querySelector<HTMLElement>('.site-nav')?.getBoundingClientRect().height ?? 0;
  const getDynamicViewportHeight = () => window.visualViewport?.height ?? window.innerHeight;
  const getIntroLogoY = () => getDynamicViewportHeight() - (
    isShortLandscape() ? 42 : isMobile() ? 68 : isTablet() ? 72 : 70
  );
  const getLayoutWidth = () => section.getBoundingClientRect().width || document.documentElement.clientWidth;
  const getActivationLead = () => (isMobile() ? 44 : isTablet() ? 52 : 58);
  const shouldReduceMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Logo helpers ──────────────────────────────────────────────────────────
  const getLogoScale = () => (isMobile() ? 0.58 : isTablet() ? 0.66 : 0.30);

  const syncLogoTooltipScale = (logo: HTMLElement, targetCenterX?: number) => {
    const tooltip = logo.querySelector<HTMLElement>('.scroll-consult-logo-tooltip');
    if (!tooltip) return;
    const scale = getLogoScale();
    if (scale <= 0) return;

    gsap.set(tooltip, {
      xPercent: -50,
      x: 0,
      y: 0,
      scale: 0.68 / scale,
      autoAlpha: 1,
      transformOrigin: '50% 100%',
    });

    // Keep the tooltip inside the viewport when the logo docks near an edge
    // (e.g., the first service dot on mobile).
    const margin = 8;
    const viewportW = document.documentElement.clientWidth;
    const clampOnce = (center: number, half: number) => {
      const minCenter = margin + half;
      const maxCenter = Math.max(minCenter, viewportW - margin - half);
      return Math.min(Math.max(center, minCenter), maxCenter) - center;
    };

    if (targetCenterX !== undefined) {
      // Logo still traveling: single estimated shift against its landing spot;
      // the post-landing resync (no target) refines it.
      const rect = tooltip.getBoundingClientRect();
      if (!rect.width) return;
      const diff = clampOnce(targetCenterX, rect.width / 2);
      if (Math.abs(diff) > 0.5) gsap.set(tooltip, { x: diff });
      return;
    }

    // Landed: iterate against the real rect. The tooltip has a CSS transition on
    // transform, so shifts must be applied with it disabled or every measurement
    // reads the still-animating old position.
    const previousTransition = tooltip.style.transition;
    tooltip.style.transition = 'none';
    for (let i = 0; i < 4; i++) {
      const rect = tooltip.getBoundingClientRect();
      if (!rect.width) break;
      const diff = clampOnce(rect.left + rect.width / 2, rect.width / 2);
      if (Math.abs(diff) <= 0.5) break;
      const currentX = Number(gsap.getProperty(tooltip, 'x')) || 0;
      gsap.set(tooltip, { x: currentX + diff });
    }
    tooltip.getBoundingClientRect();
    tooltip.style.transition = previousTransition;
  };

  const hideLogoTooltip = (logo: HTMLElement) => {
    logo.classList.remove('is-tooltip-visible');
    const tooltip = logo.querySelector<HTMLElement>('.scroll-consult-logo-tooltip');
    if (tooltip) {
      gsap.killTweensOf(tooltip);
      gsap.set(tooltip, { autoAlpha: 0 });
    }
  };

  const hideFloatingLogo = () => {
    const logo = document.querySelector<HTMLElement>('.js-scroll-consult-logo');
    if (!logo) return;
    gsap.killTweensOf(logo);
    hideLogoTooltip(logo);
    gsap.set(logo, { autoAlpha: 0, pointerEvents: 'none' });
  };

  const getLogoVars = (slideIdx: number) => {
    if (!bar) return;
    const barRect = bar.getBoundingClientRect();
    let centerY = barRect.top + barRect.height / 2;
    let centerX: number;

    if (slideIdx === 0) {
      centerX = getLayoutWidth() / 2;
      centerY = getIntroLogoY();
    } else if (slideIdx >= 1 && slideIdx <= LAST_SERVICE_SLIDE) {
      const dotRect = dots[slideIdx - 1]?.getBoundingClientRect();
      if (dotRect) {
        centerX = dotRect.left + dotRect.width / 2;
        centerY = dotRect.top + dotRect.height / 2;
      } else {
        const dotsWrap = section.querySelector<HTMLElement>('.about-snap-bar-dots-wrap');
        const wrapRect = dotsWrap?.getBoundingClientRect();
        centerX = wrapRect
          ? wrapRect.left + wrapRect.width * DOT_LEFTS[slideIdx - 1] / 100
          : getLayoutWidth() * DOT_LEFTS[slideIdx - 1] / 100;
      }
    } else {
      // Clients + Alliance: far-right logo zone
      const pct = isMobile()
        ? CLIENTS_LOGO_PCT_MOBILE
        : isTablet()
          ? CLIENTS_LOGO_PCT_TABLET
          : CLIENTS_LOGO_PCT_DESKTOP;
      centerX = getLayoutWidth() * pct / 100;
    }

    const logoVars = {
      left: centerX,
      top: centerY,
      x: 0,
      y: 0,
      xPercent: -50,
      yPercent: -50,
      scale: getLogoScale(),
      autoAlpha: 1,
      pointerEvents: 'auto',
      overwrite: true,
    } satisfies gsap.TweenVars;

    return logoVars;
  };

  const positionLogo = (slideIdx: number, animate: boolean) => {
    const logo = document.querySelector<HTMLElement>('.js-scroll-consult-logo');
    if (!logo) return;
    gsap.killTweensOf(logo);

    const logoVars = getLogoVars(slideIdx);
    if (!logoVars) return;

    const shouldShowTooltip = slideIdx <= LAST_SERVICE_SLIDE;
    logo.classList.toggle('is-tooltip-visible', shouldShowTooltip);
    if (!shouldShowTooltip) {
      hideLogoTooltip(logo);
    }

    if (animate) {
      gsap.to(logo, {
        ...logoVars,
        duration: 0.58,
        ease: 'power1.inOut',
        onComplete: () => {
          // Re-clamp against the real rendered rect once the logo has landed.
          if (shouldShowTooltip) syncLogoTooltipScale(logo);
        },
      });
      if (shouldShowTooltip) {
        syncLogoTooltipScale(logo, typeof logoVars.left === 'number' ? logoVars.left : undefined);
      }
    } else {
      gsap.set(logo, logoVars);
      if (shouldShowTooltip) syncLogoTooltipScale(logo);
    }
  };

  const updateDots = (slideIdx: number) => {
    dots.forEach((dot, i) => {
      const serviceIdx = i + 1; // service slides are 1-5
      dot.classList.toggle('is-active', slideIdx === serviceIdx);
      dot.classList.toggle('is-passed', slideIdx > serviceIdx || slideIdx >= CLIENTS_SLIDE);
    });

    if (progressEl) {
      let rightPct = 100 - DOT_LEFTS[0]; // 92.5 — zero progress
      if (slideIdx >= 2 && slideIdx <= LAST_SERVICE_SLIDE) {
        rightPct = 100 - DOT_LEFTS[slideIdx - 1];
      } else if (slideIdx >= CLIENTS_SLIDE) {
        rightPct = 100 - DOT_LEFTS[4];
      }
      progressEl.style.right = `${rightPct}%`;
    }
  };

  // ── Video hydration ───────────────────────────────────────────────────────
  const loadSlideVideos = (slide: HTMLElement, shouldPlay: boolean) => {
    slide.querySelectorAll<HTMLVideoElement>('video[data-src]').forEach((v) => {
      if (v.dataset.src && !v.currentSrc) {
        v.src = v.dataset.src;
        v.load();
      }
      if (shouldPlay) {
        ensureVideoAutoplay(v);
      } else {
        v.pause();
      }
    });
  };

  const hydrateSlide = (slide: HTMLElement) => loadSlideVideos(slide, true);

  const preloadSlide = (slide: HTMLElement | undefined) => {
    if (!slide) return;
    loadSlideVideos(slide, false);
  };

  const pauseSlide = (slide: HTMLElement) => {
    slide.querySelectorAll<HTMLVideoElement>('video').forEach((v) => v.pause());
  };

  // Warm the next section's video (video-story) as soon as the user starts the
  // alliance zoom, not when they land on it. iOS only allows autoplay to survive
  // Low Power Mode when play() runs inside a real user-gesture handler, and
  // starting it this early gives the video the most possible time to buffer
  // before the zoom's black veil finishes fading in.
  let videoStoryWarmed = false;
  const warmVideoStoryVideo = () => {
    if (videoStoryWarmed) return;
    videoStoryWarmed = true;
    const video = document.querySelector<HTMLVideoElement>('.js-video-story-frame video');
    if (!video) return;
    if (video.dataset.src && !video.currentSrc) {
      video.src = video.dataset.src;
      video.load();
    }
    ensureVideoAutoplay(video);
  };

  const renderStage = (slideIdx: number) => {
    const position = SLIDE_POSITIONS[slideIdx];
    stage.style.transform = `translate3d(${-position.x * 100}%, ${-position.y * 100}%, 0)`;
  };

  // ── Clients logo reveal ───────────────────────────────────────────────────
  const revealClients = () => {
    const clientsSlide = slides[CLIENTS_SLIDE];
    const copy = Array.from(clientsSlide.querySelectorAll<HTMLElement>('.js-about-clients-copy'));
    const stage = clientsSlide.querySelector<HTMLElement>('.js-about-clients-stage');
    const logos = Array.from(clientsSlide.querySelectorAll<HTMLElement>('.js-about-client-logo'));
    const targets = [...copy, ...(stage ? [stage] : []), ...logos];

    gsap.killTweensOf(targets);
    if (stage) {
      gsap.set(stage, { autoAlpha: 1, y: 0, scale: 1, clearProps: 'transform' });
    }

    if (shouldReduceMotion()) {
      gsap.set(targets, { autoAlpha: 1, y: 0, scale: 1 });
      return;
    }

    gsap.fromTo(
      copy,
      { autoAlpha: 0, y: 18 },
      { autoAlpha: 1, y: 0, duration: 0.52, ease: 'power2.out', overwrite: true },
    );
    gsap.fromTo(
      logos,
      { autoAlpha: 0, y: 18, scale: 0.98 },
      {
        autoAlpha: 1,
        y: 0,
        scale: 1,
        duration: 0.58,
        ease: 'power2.out',
        stagger: 0.035,
        delay: 0.1,
        overwrite: true,
      },
    );
  };

  // ── Rotación de logos de clientes ─────────────────────────────────────────
  // La rejilla muestra 15 lugares; los logos posteriores del array (reserva)
  // van entrando: cada CLIENT_LOGO_ROTATION_MS se intercambia UN lugar no
  // fijado (round-robin) con fade. Los `pinned: true` nunca rotan. Solo rota
  // mientras la lámina de clientes está activa. Config en src/data/about.ts.
  const CLIENT_LOGO_ROTATION_MS = 4000;
  const CLIENT_LOGO_FADE_S = 0.35;

  const initClientLogoRotation = () => {
    const poolScript = section.querySelector<HTMLScriptElement>('.js-client-logo-pool');
    const cards = Array.from(section.querySelectorAll<HTMLElement>('.js-about-client-logo'));
    if (!poolScript || !cards.length) return;

    type PoolLogo = { label: string; src: string; pinned?: boolean };
    let pool: PoolLogo[] = [];
    try {
      pool = JSON.parse(poolScript.textContent ?? '[]');
    } catch {
      return;
    }

    const visible = pool.slice(0, cards.length);
    const reserve = pool.slice(cards.length);
    if (!reserve.length) return; // sin reserva no hay rotación

    const rotatableSlots = cards.map((_, i) => i).filter((i) => !visible[i]?.pinned);
    if (!rotatableSlots.length) return;

    let cursor = 0;
    window.setInterval(() => {
      if (section.dataset.aboutState !== 'active') return;
      if (section.dataset.currentSlide !== String(CLIENTS_SLIDE)) return;

      const slot = rotatableSlots[cursor % rotatableSlots.length];
      cursor += 1;
      const card = cards[slot];
      const img = card.querySelector('img');
      const incoming = reserve.shift();
      if (!img || !incoming) return;

      reserve.push(visible[slot]);
      visible[slot] = incoming;

      gsap.to(card, {
        autoAlpha: 0,
        duration: CLIENT_LOGO_FADE_S,
        ease: 'power1.inOut',
        onComplete: () => {
          img.src = incoming.src;
          img.alt = `Logo cliente AGSIT ${incoming.label}`;
          gsap.to(card, { autoAlpha: 1, duration: CLIENT_LOGO_FADE_S, ease: 'power1.out' });
        },
      });
    }, CLIENT_LOGO_ROTATION_MS);
  };
  initClientLogoRotation();

  // ── Alliance scrubbed zoom ─────────────────────────────────────────────────
  // The scrub covers only the final zoom: clients→alliance travels as a normal
  // slide, so the timeline starts at the alliance resting state (content visible,
  // floating logo docked at the bar).
  const ALLIANCE_ZOOM_START = 0.16;
  const ALLIANCE_CENTER_TIME = ALLIANCE_ZOOM_START + 0.82;
  const ALLIANCE_ZOOM_READY_TIME = ALLIANCE_ZOOM_START + 2.05;
  const CENTERED_ALLIANCE_STEP = 8;
  const VIDEO_HANDOFF_STEP = 9;

  const showSlidesForAllianceScrub = () => {
    slides.forEach((slide, i) => {
      const isVisible = i === CLIENTS_SLIDE || i === ALLIANCE_SLIDE;
      slide.style.visibility = isVisible ? 'visible' : 'hidden';
      slide.style.zIndex = i === ALLIANCE_SLIDE ? '3' : i === CLIENTS_SLIDE ? '2' : '1';
      slide.classList.toggle('is-active', i === ALLIANCE_SLIDE);
    });
  };

  const buildAllianceScrubTimeline = () => {
    const allianceSlide   = slides[ALLIANCE_SLIDE];
    const floatingLogo    = document.querySelector<HTMLElement>('.js-scroll-consult-logo');
    const transitionLogo  = allianceSlide.querySelector<HTMLElement>('.js-about-transition-logo');
    const transitionVeil  = allianceSlide.querySelector<HTMLElement>('.js-about-transition-veil');
    const metricsEls      = Array.from(allianceSlide.querySelectorAll<HTMLElement>('.js-about-alliance-metric'));
    const allianceCopy    = Array.from(allianceSlide.querySelectorAll<HTMLElement>('.js-about-alliance-copy'));
    const allianceCta     = Array.from(allianceSlide.querySelectorAll<HTMLElement>('.js-about-alliance-cta'));
    const logoVars        = getLogoVars(ALLIANCE_SLIDE);

    if (!floatingLogo || !transitionLogo || !transitionVeil || !logoVars) return undefined;
    gsap.killTweensOf([
      stage,
      floatingLogo,
      transitionLogo,
      transitionVeil,
      ...allianceCopy,
      ...metricsEls,
      ...allianceCta,
    ]);

    const alliancePos = SLIDE_POSITIONS[ALLIANCE_SLIDE];
    const stageRect = stage.getBoundingClientRect();
    const stageW = stageRect.width || window.innerWidth;
    const stageH = stageRect.height || getAboutPanelHeight();
    const tl = gsap.timeline({ paused: true });

    tl.set(stage, {
      x: -alliancePos.x * stageW,
      y: -alliancePos.y * stageH,
      xPercent: 0,
      yPercent: 0,
    }, 0);
    tl.set(allianceSlide, { backgroundColor: '#ffffff' }, 0);
    tl.set(transitionVeil, { autoAlpha: 0 }, 0);
    tl.set(transitionLogo, {
      autoAlpha: 0,
      scale: 0.68 / ALLIANCE_LOGO_OVERSAMPLE,
      x: 0,
      y: 0,
      xPercent: -50,
      yPercent: -50,
      rotate: 0,
      backgroundColor: 'rgba(2, 7, 18, 0)',
    }, 0);
    tl.set(allianceCopy, { autoAlpha: 1, y: 0 }, 0);
    tl.set(metricsEls, { autoAlpha: 1, y: 0, scale: 1 }, 0);
    tl.set(allianceCta, { autoAlpha: 1, y: 0, pointerEvents: 'auto' }, 0);
    // Keep-alive fromTo with explicit values at position 0: when the timeline is
    // rebuilt on re-entry from below, a plain .to() would capture the logo's hidden
    // post-exit state, and GSAP reverts targets to their pre-timeline state when
    // the playhead lands before a tween's start — either way the logo would blink.
    const { overwrite: _o, ...restingLogoVars } = logoVars;
    tl.fromTo(floatingLogo, restingLogoVars, {
      ...restingLogoVars,
      duration: ALLIANCE_ZOOM_START,
      ease: 'none',
      immediateRender: false,
    }, 0);

    const zoomDuration = initAllianceLogoZoom({
      timeline: tl,
      startAt: ALLIANCE_ZOOM_START,
      panelEl: allianceSlide,
      floatingLogoEl: floatingLogo,
      transitionLogoEl: transitionLogo,
      veilEl: transitionVeil,
      metricsEls,
      contentEls: [...allianceCopy, ...allianceCta],
      // Before the handoff starts, preserve About's native dynamic viewport.
      // Once it starts, every participant reads the captured height.
      getViewportHeight: () => handoff.snapshot.viewportHeight ?? getDynamicViewportHeight(),
    });
    tl.to({}, { duration: zoomDuration }, ALLIANCE_ZOOM_START);

    return tl;
  };

  const ensureAllianceScrub = (startTime: number) => {
    showSlidesForAllianceScrub();
    section.dataset.currentSlide = String(ALLIANCE_SLIDE);
    updateDots(ALLIANCE_SLIDE);
    const logo = document.querySelector<HTMLElement>('.js-scroll-consult-logo');
    logo?.classList.remove('is-tooltip-visible');
    const tooltip = logo?.querySelector<HTMLElement>('.scroll-consult-logo-tooltip');
    if (tooltip) gsap.set(tooltip, { autoAlpha: 0 });

    allianceScrubTl?.kill();
    allianceScrubTween?.kill();
    allianceScrubTl = buildAllianceScrubTimeline();
    if (!allianceScrubTl) return;

    warmVideoStoryVideo();
    isAllianceScrubbing = true;
    current = ALLIANCE_SLIDE;
    allianceDone = false;
    alliancePlayed = false;
    // Nunca exactamente 0: los .set() en la posición 0 de la timeline no
    // disparan con el playhead clavado en 0 (ni al llegar en reversa), y la
    // lámina de alianza quedaría con su contenido oculto (pantalla en blanco).
    allianceScrubTime = gsap.utils.clamp(0.001, allianceScrubTl.duration(), startTime);
    allianceScrubTl.time(allianceScrubTime);
  };

  // ── On slide arrival ──────────────────────────────────────────────────────
  const onSlideArrival = (slideIdx: number, animate: boolean) => {
    section.dataset.currentSlide = String(slideIdx);
    updateDots(slideIdx);
    positionLogo(slideIdx, animate);

    if (slideIdx === CLIENTS_SLIDE) {
      revealClients();
    }

    if (slideIdx === ALLIANCE_SLIDE) {
      const allianceSlide = slides[ALLIANCE_SLIDE];
      if (alliancePlayed) {
        // Re-entry: reset state so zoom can replay cleanly
        gsap.set(allianceSlide.querySelector('.js-about-transition-veil'),  { autoAlpha: 0 });
        gsap.set(allianceSlide.querySelector('.js-about-transition-logo'),  {
          autoAlpha: 0, scale: 0.68 / ALLIANCE_LOGO_OVERSAMPLE, x: 0, y: 0, xPercent: -50, yPercent: -50, rotate: 0,
        });
        gsap.set(allianceSlide.querySelectorAll('.js-about-alliance-copy'),   { autoAlpha: 0, y: 24 });
        gsap.set(allianceSlide.querySelectorAll('.js-about-alliance-metric'), { autoAlpha: 0, y: 22, scale: 0.96 });
        gsap.set(allianceSlide.querySelectorAll('.js-about-alliance-cta'),    { autoAlpha: 0, y: 16, pointerEvents: 'none' });
        alliancePlayed = false;
        allianceDone   = false;
      }
      // 1. Reveal alliance content — zoom will then use it as "before" state and hide it
      gsap.to(allianceSlide.querySelectorAll('.js-about-alliance-copy'), {
        autoAlpha: 1, y: 0, duration: 0.7, ease: 'power2.out', delay: 0.15,
      });
      gsap.to(allianceSlide.querySelectorAll('.js-about-alliance-metric'), {
        autoAlpha: 1, y: 0, scale: 1, duration: 0.5, ease: 'power3.out', stagger: 0.08, delay: 0.4,
      });
      gsap.to(allianceSlide.querySelectorAll('.js-about-alliance-cta'), {
        autoAlpha: 1, y: 0, pointerEvents: 'auto', duration: 0.5, ease: 'power2.out', delay: 0.6,
      });
    }

    // Hydrate incoming video and warm the next slide before it enters.
    hydrateSlide(slides[slideIdx]);
    preloadSlide(slides[slideIdx + 1]);
  };

  // Re-dock the logo when the mobile browser UI shows/hides (viewport height change).
  let allianceViewportRebuildFrame = 0;
  window.addEventListener(
    'agsit:viewport-change',
    (event) => {
      const viewportEvent = event as CustomEvent<{ dynamicChanged?: boolean }>;

      // La timeline de alianza usa traslaciones en píxeles para alinear la
      // cuadrícula horizontal. Cuando Chrome modifica el alto visible, esas
      // coordenadas deben reconstruirse; de lo contrario el logo queda fuera
      // de su centro al recorrer los slides en reversa.
      if (
        isActive &&
        isShortLandscape() &&
        viewportEvent.detail?.dynamicChanged &&
        isAllianceScrubbing &&
        !isAllianceTravelPlaying &&
        !isAnimating &&
        zoomHandoffState === 'idle'
      ) {
        cancelAnimationFrame(allianceViewportRebuildFrame);
        allianceViewportRebuildFrame = requestAnimationFrame(() => {
          allianceViewportRebuildFrame = 0;
          if (
            isActive &&
            isAllianceScrubbing &&
            !isAllianceTravelPlaying &&
            !isAnimating &&
            zoomHandoffState === 'idle'
          ) {
            ensureAllianceScrub(allianceScrubTl?.time() ?? allianceScrubTime);
          }
        });
        return;
      }

      if (isActive && !isAllianceScrubbing && !isAnimating) {
        positionLogo(current, false);
      }
    },
    { passive: true },
  );

  // ── Real-scroll sync ──────────────────────────────────────────────────────
  let aboutSyncFrame = 0;
  let zoomHandoffState: 'idle' | 'forward' | 'done' | 'reverse' = 'idle';
  let isAllianceAtCenter = false;
  let isAllianceTravelPlaying = false;
  type UserScrollDirection = -1 | 0 | 1;
  const USER_SCROLL_INTENT_TTL = 1400;
  let userScrollIntent: UserScrollDirection = 0;
  let userScrollIntentAt = 0;
  let lastTouchY: number | null = null;

  const rememberUserScrollIntent = (direction: Exclude<UserScrollDirection, 0>) => {
    userScrollIntent = direction;
    userScrollIntentAt = performance.now();
  };

  const hasRecentUserScrollIntent = (direction: Exclude<UserScrollDirection, 0>) =>
    userScrollIntent === direction && performance.now() - userScrollIntentAt <= USER_SCROLL_INTENT_TTL;

  const consumeUserScrollIntent = (direction: Exclude<UserScrollDirection, 0>) => {
    if (!hasRecentUserScrollIntent(direction)) return false;
    userScrollIntent = 0;
    userScrollIntentAt = 0;
    return true;
  };

  const onTouchStart = (event: TouchEvent) => {
    lastTouchY = event.touches[0]?.clientY ?? null;
    userScrollIntent = 0;
    userScrollIntentAt = 0;

    // En iOS/iPadOS play() debe ocurrir dentro del gesto real. Al tocar la
    // parada centrada, desbloquea el video antes de que el scroll y el tween
    // asíncrono consuman la activación del usuario.
    if (
      zoomHandoffState === 'idle' &&
      isAllianceAtCenter &&
      section.dataset.aboutState === 'active'
    ) {
      warmVideoStoryVideo();
    }
  };

  const onTouchMove = (event: TouchEvent) => {
    const currentY = event.touches[0]?.clientY;
    if (currentY === undefined || lastTouchY === null) return;
    const delta = lastTouchY - currentY;
    lastTouchY = currentY;
    if (Math.abs(delta) < 4) return;
    rememberUserScrollIntent(delta > 0 ? 1 : -1);
  };

  const onTouchEnd = () => {
    lastTouchY = null;
  };

  const onScrollIntentKeyDown = (event: KeyboardEvent) => {
    const target = event.target as HTMLElement | null;
    if (target?.closest('input, textarea, select, [contenteditable="true"]')) return;

    if (event.key === 'ArrowDown' || event.key === 'PageDown' || (event.key === ' ' && !event.shiftKey)) {
      rememberUserScrollIntent(1);
    } else if (event.key === 'ArrowUp' || event.key === 'PageUp' || (event.key === ' ' && event.shiftKey)) {
      rememberUserScrollIntent(-1);
    }
  };

  window.addEventListener('touchstart', onTouchStart, { passive: true, capture: true });
  window.addEventListener('touchmove', onTouchMove, { passive: true, capture: true });
  window.addEventListener('touchend', onTouchEnd, { passive: true, capture: true });
  window.addEventListener('touchcancel', onTouchEnd, { passive: true, capture: true });
  window.addEventListener('keydown', onScrollIntentKeyDown, { capture: true });

  if (new URLSearchParams(window.location.search).get('debugScroll') === '1') {
    window.addEventListener('agsit:debug-scroll-snapshot', (event) => {
      (event as CustomEvent<{ allianceTime: number | null }>).detail.allianceTime = allianceScrubTl?.time() ?? null;
    });
  }

  const getAboutPanelHeight = () => {
    if (handoff.snapshot.viewportHeight) {
      return Math.max(handoff.getViewportHeight() - getNavH(), 1);
    }
    const viewportVariable = isShortLandscape() ? '--app-vh' : '--app-stable-vh';
    const viewportValue = Number.parseFloat(getComputedStyle(document.documentElement).getPropertyValue(viewportVariable));
    const viewportHeight = Number.isFinite(viewportValue) && viewportValue > 0 ? viewportValue : window.innerHeight;
    return Math.max(viewportHeight - getNavH(), 1);
  };

  const getAboutScrollStart = () => window.scrollY + section.getBoundingClientRect().top - getNavH();

  const scrollToAboutStep = (step: number, behavior: ScrollBehavior = 'auto') => {
    window.scrollTo({
      top: getAboutScrollStart() + getAboutPanelHeight() * step,
      left: 0,
      behavior,
    });
  };

  // Una sola transición en vuelo: los eventos de scroll llegan en ráfaga
  // durante el snap y sin este candado la transición se re-dispara en cada
  // evento y encola timeouts de llegada que caen cuando el scrub de la
  // alianza ya está activo (matando los tweens del logo flotante).
  let pendingSlideTarget = -1;
  let slideSettleTimeout = 0;

  const settlePendingSlide = () => {
    if (pendingSlideTarget < 0) return;
    window.clearTimeout(slideSettleTimeout);
    const previous = current;
    const next = pendingSlideTarget;
    pendingSlideTarget = -1;
    const currentEl = slides[previous] ?? slides[0];
    const targetEl = slides[next];

    if (currentEl !== targetEl) {
      currentEl.style.visibility = 'hidden';
      currentEl.style.zIndex = '1';
    }
    targetEl.style.zIndex = '2';
    slides[previous]?.classList.remove('is-active');
    targetEl.classList.add('is-active');
    pauseSlide(currentEl);
    current = next;
    isAnimating = false;

    if (!isAllianceScrubbing) {
      onSlideArrival(current, false);
    }
  };

  const setNormalSlideFromScroll = (target: number) => {
    const next = gsap.utils.clamp(0, ALLIANCE_SLIDE, target);

    if (isAllianceScrubbing && next !== ALLIANCE_SLIDE) {
      allianceScrubTween?.kill();
      allianceScrubTl?.kill();
      allianceScrubTween = undefined;
      allianceScrubTl = undefined;
      isAllianceScrubbing = false;
      allianceScrubTime = 0;
      allianceDone = false;
      alliancePlayed = false;
    }

    if (isAllianceScrubbing) {
      // El scrub de la alianza es dueño del estado. Si el progreso oscila
      // apenas por debajo de 7 al reposar, re-disparar la llegada llamaría a
      // positionLogo, que mata los tweens del logo dentro de la timeline
      // scrubeada y la transición al centro deja de verse.
      return;
    }

    if (pendingSlideTarget === next) return;

    if (pendingSlideTarget >= 0) {
      // Retarget en pleno vuelo (scroll rápido): asienta la transición previa
      // al instante para no dejar slides visibles con z-index colgado.
      settlePendingSlide();
    }

    if (current === next) {
      onSlideArrival(next, false);
      return;
    }

    const previous = current;
    const currentEl = slides[previous] ?? slides[0];
    const targetEl = slides[next];

    section.dataset.currentSlide = String(next);
    updateDots(next);
    positionLogo(next, true);
    hydrateSlide(targetEl);
    preloadSlide(slides[next + 1]);

    targetEl.style.visibility = 'visible';
    targetEl.style.zIndex = '3';
    currentEl.style.zIndex = '2';
    stage.style.transition = shouldReduceMotion() ? 'none' : 'transform 900ms cubic-bezier(0.76, 0, 0.24, 1)';
    renderStage(next);
    isAnimating = true;
    pendingSlideTarget = next;
    slideSettleTimeout = window.setTimeout(settlePendingSlide, shouldReduceMotion() ? 0 : ANIM_MS);
  };

  const setAllianceCenterProgress = (progress: number) => {
    const centeredProgress = gsap.utils.clamp(0, 1, progress);

    if (!isAllianceScrubbing) {
      ensureAllianceScrub(0);
    }

    if (!allianceScrubTl) return;

    allianceScrubTween?.kill();
    allianceScrubTween = undefined;
    current = ALLIANCE_SLIDE;
    isAnimating = false;
    isAllianceAtCenter = centeredProgress >= 0.999;
    section.dataset.currentSlide = String(ALLIANCE_SLIDE);
    updateDots(ALLIANCE_SLIDE);
    allianceDone = false;
    alliancePlayed = false;
    // 0.001 y no 0: ver nota del nudge en ensureAllianceScrub.
    allianceScrubTime = Math.max(ALLIANCE_CENTER_TIME * centeredProgress, 0.001);
    allianceScrubTl.time(allianceScrubTime);
  };

  const lockAllianceAtCenter = () => {
    if (!allianceScrubTl) {
      ensureAllianceScrub(ALLIANCE_CENTER_TIME);
    }

    if (!allianceScrubTl) return;

    allianceScrubTween?.kill();
    allianceScrubTween = undefined;
    zoomHandoffState = 'idle';
    isAnimating = false;
    isAllianceScrubbing = true;
    isAllianceAtCenter = true;
    allianceDone = false;
    alliancePlayed = false;
    current = ALLIANCE_SLIDE;
    section.dataset.aboutState = 'active';
    section.dataset.currentSlide = String(ALLIANCE_SLIDE);
    updateDots(ALLIANCE_SLIDE);
    allianceScrubTime = ALLIANCE_CENTER_TIME;
    allianceScrubTl.time(ALLIANCE_CENTER_TIME);
  };

  // ── Viaje disparado del logo (parada 7 ⇄ centro) ──────────────────────────
  // Un solo scroll dispara la animación completa: bajando, el logo viaja de la
  // barra al centro y se detiene (el zoom es el siguiente scroll); subiendo
  // desde el centro, el viaje completo de regreso a la barra. Durante la
  // animación la página queda quieta y la rueda está en lockout, como en
  // cualquier transición de slide. El táctil sigue con el scroll nativo.
  const playAllianceCenterTravel = (direction: 1 | -1) => {
    if (isAllianceTravelPlaying) return;

    if (!isAllianceScrubbing || !allianceScrubTl) {
      ensureAllianceScrub(direction > 0 ? 0 : ALLIANCE_CENTER_TIME);
    }
    if (!allianceScrubTl) return;

    // 0.001 y no 0: ver nota del nudge en ensureAllianceScrub.
    const targetTime = direction > 0 ? ALLIANCE_CENTER_TIME : 0.001;
    isAllianceTravelPlaying = true;
    allianceScrubTween?.kill();
    allianceScrubTween = allianceScrubTl.tweenTo(targetTime, {
      duration: shouldReduceMotion() ? 0 : 1,
      ease: 'power2.inOut',
      onComplete: () => {
        allianceScrubTween = undefined;
        allianceScrubTime = targetTime;
        isAllianceTravelPlaying = false;

        if (direction > 0) {
          lockAllianceAtCenter();
          handoff.setState('alliance-centering');
          scrollToAboutStep(CENTERED_ALLIANCE_STEP);
        } else {
          isAllianceAtCenter = false;
          scrollToAboutStep(ALLIANCE_SLIDE);
        }
      },
    });
  };

  const onAllianceWheel = (event: WheelEvent) => {
    if (event.deltaY === 0) return;
    rememberUserScrollIntent(event.deltaY > 0 ? 1 : -1);
    if (zoomHandoffState !== 'idle') return;
    if (section.dataset.aboutState !== 'active') return;

    if (isAllianceTravelPlaying) {
      // Lockout: la animación en curso es dueña del gesto.
      event.preventDefault();
      return;
    }

    const rect = section.getBoundingClientRect();
    const progress = (getNavH() - rect.top) / getAboutPanelHeight();

    // Bajada: en reposo en la lámina de alianza con el logo anclado a la barra.
    if (event.deltaY > 0 && !isAllianceAtCenter && Math.abs(progress - ALLIANCE_SLIDE) < 0.05) {
      const currentTime = isAllianceScrubbing && allianceScrubTl ? allianceScrubTl.time() : 0;

      if (currentTime < ALLIANCE_CENTER_TIME - 0.005) {
        event.preventDefault();
        playAllianceCenterTravel(1);
      }
      return;
    }

    // Subida: centrado en la parada 8, un scroll regresa el logo a la barra.
    if (event.deltaY < 0 && isAllianceAtCenter && Math.abs(progress - CENTERED_ALLIANCE_STEP) < 0.05) {
      event.preventDefault();
      playAllianceCenterTravel(-1);
    }
  };

  const playZoomForwardToVideo = () => {
    if (zoomHandoffState === 'forward' || zoomHandoffState === 'done') return;

    if (!handoff.beginAllianceZoom()) return;
    consumeUserScrollIntent(1);

    if (!allianceScrubTl || !isAllianceScrubbing) {
      ensureAllianceScrub(ALLIANCE_CENTER_TIME);
    } else {
      allianceScrubTween?.kill();
      allianceScrubTween = undefined;
      allianceScrubTime = ALLIANCE_CENTER_TIME;
      allianceScrubTl.time(ALLIANCE_CENTER_TIME);
    }

    if (!allianceScrubTl) return;

    isAllianceAtCenter = true;
    allianceScrubTime = ALLIANCE_ZOOM_READY_TIME;
    allianceScrubTl.time(ALLIANCE_ZOOM_READY_TIME);

    zoomHandoffState = 'forward';
    isAnimating = true;
    warmVideoStoryVideo();
    allianceScrubTween?.kill();
    const completeForwardHandoff = () => {
      if (zoomHandoffState !== 'forward') return;
      window.clearTimeout(forwardHandoffTimeout);
      forwardHandoffTimeout = 0;
      const videoStory = document.querySelector<HTMLElement>('.js-video-story');
      zoomHandoffState = 'done';
      isAnimating = false;
      isAllianceScrubbing = false;
      allianceDone = true;
      alliancePlayed = true;
      section.dataset.aboutState = 'done';
      hideFloatingLogo();

      if (videoStory) {
        const handoffEvent = new CustomEvent('agsit:show-video-story-ready', { cancelable: true });
        window.dispatchEvent(handoffEvent);
      }
    };
    const forceCompleteForwardHandoff = () => {
      if (zoomHandoffState !== 'forward' || !allianceScrubTl) return;

      // Mobile Safari puede dormir el ticker de GSAP mientras termina el
      // desplazamiento táctil. El tiempo real del handoff no debe depender de
      // otro tap: asienta el último frame visual y continúa hacia el video.
      allianceScrubTween?.kill();
      allianceScrubTween = undefined;
      allianceScrubTime = allianceScrubTl.duration();
      allianceScrubTl.time(allianceScrubTime);
      completeForwardHandoff();
    };
    allianceScrubTween = gsap.to(allianceScrubTl, {
      time: allianceScrubTl.duration(),
      duration: shouldReduceMotion() ? 0 : 0.95,
      ease: 'power1.inOut',
      onComplete: () => {
        completeForwardHandoff();
      },
    });
    window.clearTimeout(forwardHandoffTimeout);
    forwardHandoffTimeout = window.setTimeout(
      forceCompleteForwardHandoff,
      shouldReduceMotion() ? 0 : 1250,
    );
  };

  const playZoomReverseToAlliance = () => {
    if (zoomHandoffState === 'reverse') return;

    window.clearTimeout(forwardHandoffTimeout);
    forwardHandoffTimeout = 0;

    section.dataset.aboutState = 'active';
    ensureAllianceScrub(allianceScrubTl?.duration() ?? Number.POSITIVE_INFINITY);
    if (!allianceScrubTl) return;

    zoomHandoffState = 'reverse';
    isAnimating = true;
    isAllianceAtCenter = true;
    allianceScrubTween?.kill();

    const completeReverseHandoff = () => {
      if (zoomHandoffState !== 'reverse') return;
      lockAllianceAtCenter();
      // Defensive final state for Android/Safari compositors: the timeline is
      // already at ALLIANCE_CENTER_TIME, but a previously promoted veil layer
      // can otherwise remain painted for one or more frames.
      gsap.set(slides[ALLIANCE_SLIDE], { backgroundColor: '#ffffff' });
      gsap.set(slides[ALLIANCE_SLIDE].querySelector('.js-about-transition-veil'), { autoAlpha: 0 });
      handoff.finishReturn();
      scrollToAboutStep(CENTERED_ALLIANCE_STEP);
    };
    // Espejo VISIBLE del zoom de ida: la propia timeline desvanece el velo y
    // encoge el logo gigante sobre el panel blanco (las franjas blancas que
    // antes obligaban a mantener el velo sólido eran el desfase de alturas,
    // ya congeladas con --handoff-vh). Dos fases: el tramo del zoom a la
    // misma velocidad que la ida (0.95s por unidad) y un asentamiento corto
    // por la zona muerta hasta el centro.
    allianceScrubTween = gsap.to(allianceScrubTl, {
      time: ALLIANCE_ZOOM_READY_TIME,
      duration: shouldReduceMotion() ? 0 : 0.95,
      ease: 'power1.inOut',
      onComplete: () => {
        if (zoomHandoffState !== 'reverse' || !allianceScrubTl) return;
        allianceScrubTween = gsap.to(allianceScrubTl, {
          time: ALLIANCE_CENTER_TIME,
          duration: shouldReduceMotion() ? 0 : 0.35,
          ease: 'power1.out',
          onComplete: completeReverseHandoff,
        });
      },
    });
  };

  // Arranque compartido de la reversa video→alianza (rueda en el tope del video
  // o re-entrada con estado 'done'). SIEMPRE fija primero el scroll en la parada
  // 9: la timeline hornea coordenadas de pantalla del logo flotante (posición
  // de la barra) y si se construye con el viewport sticky aún desplazado hacia
  // el video, el reposo del logo queda arriba en vez de anclado a la barra.
  const beginReverseHandoffFromVideo = () => {
    if (zoomHandoffState === 'reverse') return;

    if (handoff.snapshot.state !== 'returning-alliance' && !handoff.beginReturn()) return;

    document.documentElement.classList.add('home-snap-active');

    requestAnimationFrame(() => {
      if (handoff.snapshot.state !== 'returning-alliance') return;
      // El primer frame pinta el overlay fijo negro; después se corrige scroll
      // debajo de él. Separar ambas escrituras evita el flash de capas sticky
      // que WebKit produce cuando scrollTo coincide con un cambio de layout.
      scrollToAboutStep(VIDEO_HANDOFF_STEP);
      requestAnimationFrame(() => {
        // Otro disparo pudo ganar la carrera (rueda + sync de scroll): no
        // reconstruyas la timeline debajo del tween en curso.
        if (zoomHandoffState === 'reverse') {
          return;
        }
        ensureAllianceScrub(allianceScrubTl?.duration() ?? Number.POSITIVE_INFINITY);
        if (allianceScrubTl) {
          allianceScrubTime = allianceScrubTl.duration();
          allianceScrubTl.time(allianceScrubTime);
        }
        playZoomReverseToAlliance();
      });
    });
  };

  const returnFromVideoStoryToAlliance = (event: Event) => {
    event.preventDefault();
    beginReverseHandoffFromVideo();
  };

  const syncAboutToScroll = () => {
    aboutSyncFrame = 0;
    const rect = section.getBoundingClientRect();
    const navH = getNavH();
    const isWithinSection = rect.top <= navH + getActivationLead() && rect.bottom > navH;

    if (!isWithinSection) {
      if (isActive && rect.bottom <= navH) {
        section.dataset.aboutState = 'done';
      } else if (isActive) {
        delete section.dataset.aboutState;
      }
      isActive = false;
      if (zoomHandoffState !== 'forward' && zoomHandoffState !== 'reverse') {
        hideFloatingLogo();
      }
      return;
    }

    isActive = true;
    section.dataset.aboutState = 'active';
    const progress = gsap.utils.clamp(0, VIDEO_HANDOFF_STEP, (navH - rect.top) / getAboutPanelHeight());

    if (zoomHandoffState === 'forward' || zoomHandoffState === 'reverse') {
      return;
    }

    if (zoomHandoffState === 'done') {
      // Una reversa en curso corrige su propio scroll sin exigir gesto.
      if (handoff.snapshot.state === 'returning-alliance') {
        if (rect.bottom > navH + 2) {
          beginReverseHandoffFromVideo();
        }
        return;
      }
      // The veil remains the owner while the video is decoding and while the
      // browser settles on its fullscreen stop. Do not interpret those scroll
      // events as a reverse re-entry into About. 'video-fullscreen' SÍ debe
      // poder regresar: en táctil no hay wheel, y salir de esa parada hacia
      // arriba solo puede resolverse aquí — sin esto el estado queda atrapado
      // y el velo oscuro cubre About permanentemente al subir.
      if (handoff.isActive && handoff.snapshot.state !== 'video-fullscreen') {
        return;
      }
      // Re-entrada táctil desde el video. window.scrollY NO identifica intención
      // en iOS: scroll-snap, scrollTo y la barra de Safari también lo modifican.
      // Solo una dirección capturada desde touchmove puede iniciar la reversa.
      const reverseMargin = handoff.snapshot.state === 'video-fullscreen' ? 24 : 8;
      const canReturnFromVideo =
        handoff.snapshot.state !== 'video-fullscreen' || handoff.isVideoFullscreenSettled;
      if (
        canReturnFromVideo &&
        rect.bottom > navH + reverseMargin &&
        consumeUserScrollIntent(-1)
      ) {
        beginReverseHandoffFromVideo();
      }
      return;
    }

    if (isAllianceTravelPlaying) {
      // La animación disparada corre con la página quieta en una parada; los
      // eventos espurios (resize, viewport-change) no deben pisar la timeline.
      return;
    }

    if (progress < ALLIANCE_SLIDE) {
      zoomHandoffState = 'idle';
      isAllianceAtCenter = false;
      setNormalSlideFromScroll(Math.round(progress));
      return;
    }

    if (progress < CENTERED_ALLIANCE_STEP) {
      zoomHandoffState = 'idle';
      setAllianceCenterProgress(progress - ALLIANCE_SLIDE);
      return;
    }

    if (progress < VIDEO_HANDOFF_STEP - 0.18) {
      zoomHandoffState = 'idle';
      if (!isAllianceAtCenter) {
        lockAllianceAtCenter();
      }
      return;
    }

    // Solo un touchmove/wheel descendente reciente puede iniciar el zoom. Los
    // deltas generados por snap, scrollTo o resize no crean intención nueva.
    if (consumeUserScrollIntent(1)) {
      playZoomForwardToVideo();
    }
  };

  const requestAboutSync = () => {
    if (aboutSyncFrame) return;
    aboutSyncFrame = requestAnimationFrame(syncAboutToScroll);
  };

  // The section follows real scroll positions (native snap drives the browser
  // scrollbar one step per slide); syncAboutToScroll is the single source of truth.
  window.addEventListener('scroll', requestAboutSync, { passive: true });
  window.addEventListener('resize', requestAboutSync, { passive: true });
  window.addEventListener('agsit:viewport-change', requestAboutSync, { passive: true });
  window.addEventListener('agsit:return-about-alliance', returnFromVideoStoryToAlliance);
  // Capture: reclama el tick antes de que el snap nativo arranque el viaje 7⇄8.
  window.addEventListener('wheel', onAllianceWheel, { passive: false, capture: true });

  // ── Initial slide state ───────────────────────────────────────────────────
  stage.style.transition = 'none';
  slides.forEach((slide, i) => {
    const position = SLIDE_POSITIONS[i];
    slide.style.transform = `translate3d(${position.x * 100}%, ${position.y * 100}%, 0)`;
    slide.style.zIndex = i === 0 ? '2' : '1';
    if (i === 0) {
      slide.style.visibility = 'visible';
      slide.classList.add('is-active');
    } else {
      slide.style.visibility = 'hidden';
    }
  });
  renderStage(0);
  updateDots(0);
  hideFloatingLogo();
  preloadSlide(slides[1]);
</script>
