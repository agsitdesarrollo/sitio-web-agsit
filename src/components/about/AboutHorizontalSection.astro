---
import { Image } from 'astro:assets';
import type { AboutContent } from '../../data/about';
// import { clientLogos } from '../../data/about';
import logoImage from '../../assets/images/logo-asit.webp';

type Props = {
  content: AboutContent;
};

const { content } = Astro.props;

// side per service index (0-based): even = texto-right/video-left, odd = texto-left/video-right
const serviceSides = content.services.map((_, i) => (i % 2 === 0 ? 'text-right' : 'text-left'));
---

<section
  id="servicios"
  class="about-snap-section js-about-snap"
  aria-label={content.sectionLabel}
>
  <div class="about-snap-stage">

    <!-- Slide 0: Intro -->
    <div class="about-snap-slide about-snap-slide--intro is-active" data-slide="0">
      <div class="about-overview">
        <p class="about-overview-kicker">{content.overview.kicker}</p>
        <h2 class="about-overview-title">
          {content.overview.title}
          <span>{content.overview.titleAccent}</span>
        </h2>
        <p class="about-overview-copy">{content.overview.copy}</p>
        <p class="about-overview-scroll">{content.overview.scroll}</p>
      </div>
    </div>

    <!-- Slides 1-5: Services -->
    {
      content.services.map((service, i) => (
        <div class="about-snap-slide about-snap-slide--service" data-slide={i + 1}>
          <article
            class="about-service-story js-about-service-card"
            data-side={serviceSides[i]}
            aria-label={service.alt}
          >
            <div class="about-service-image-frame js-about-service-visual">
              <video
                data-src={service.image}
                poster="/assets/fondo-ventana.webp"
                muted
                loop
                playsinline
                preload="metadata"
              />
            </div>
            <div class="about-service-body js-about-service-body">
              <p class="about-service-number" aria-hidden="true">{service.number}</p>
              <p class="about-service-code">
                {service.code} – {service.label}
              </p>
              <h3>{service.title}</h3>
              <p class="about-service-description">{service.description}</p>
              <div class="about-service-tags">
                {service.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
              {service.href ? (
                <a class="about-service-link" href={service.href}>
                  {content.serviceLinkLabel} {service.code} →
                </a>
              ) : (
                <p class="about-service-link">
                  {content.serviceLinkLabel} {service.code} →
                </p>
              )}
            </div>
          </article>
        </div>
      ))
    }

    <!-- Slide 6: Clients
    <div class="about-snap-slide about-snap-slide--clients" data-slide="6">
      <div class="about-clients-copy js-about-clients-copy">
        <h2>{content.clients.title}</h2>
        <p>{content.clients.copy}</p>
      </div>
      <div class="about-clients-stage js-about-clients-stage">
        <canvas
          class="about-clients-canvas"
          aria-hidden="true"
          data-items={JSON.stringify(clientLogos)}
        />
      </div>
    </div>
    -->

    <!-- Slide 6: Alliance -->
    <div class="about-snap-slide about-snap-slide--alliance" data-slide="6">
      <div class="about-transition-veil js-about-transition-veil" aria-hidden="true"></div>
      <div class="about-alliance-layout">
        <div class="about-alliance-copy js-about-alliance-copy">
          <h2
            class="about-alliance-title"
            aria-label={content.alliance.titleLabel}
          >
            {content.alliance.titleLines.map((line) => (
              <span class="about-alliance-title-line">{line}</span>
            ))}
          </h2>
          <p>{content.alliance.copy}</p>
        </div>
        <div
          class="about-transition-logo js-about-transition-logo"
          aria-hidden="true"
        >
          <Image
            class="about-transition-logo-image"
            src={logoImage}
            alt=""
            loading="lazy"
            draggable="false"
          />
        </div>
        <div class="about-alliance-triangle-wrap" aria-hidden="true">
          <span class="about-alliance-metric about-alliance-metric-scope js-about-alliance-metric">
            {content.alliance.metrics.scope}
          </span>
          <div class="about-alliance-triangle-spacer"></div>
          <div class="about-alliance-triangle-bottom">
            <span class="about-alliance-metric about-alliance-metric-cost js-about-alliance-metric pl-9">
              {content.alliance.metrics.cost}
            </span>
            <span class="about-alliance-metric about-alliance-metric-time js-about-alliance-metric max-sm:pr-8">
              {content.alliance.metrics.time}
            </span>
          </div>
        </div>
        <button
          class="about-alliance-cta js-about-alliance-cta"
          type="button"
          data-contact-trigger
        >
          {content.alliance.cta}
        </button>
      </div>
    </div>

  </div><!-- /about-snap-stage -->

  <!-- Bottom bar: always visible -->
  <div class="about-snap-bar js-about-snap-bar" aria-hidden="true">
    <div class="about-snap-bar-dots-wrap">
      <div class="about-snap-bar-line"></div>
      <div class="about-snap-bar-progress js-bar-progress"></div>
      {
        content.services.map((_, i) => (
          <div class="about-snap-dot js-about-snap-dot" data-dot={i}>
            <span class="about-snap-dot-number">{i + 1}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { initAllianceLogoZoom } from '../../animations/allianceLogoZoom';
  // import { initClientsPhysicsCanvas } from './clientsPhysicsCanvas';
  // import type { ClientLogo } from '../../data/about';

  // ── Physics canvas ────────────────────────────────────────────────────────
  /*
  const initClientsIdle = () => {
    const canvas = document.querySelector<HTMLCanvasElement>('.about-clients-canvas');
    if (!canvas) return;
    const items = JSON.parse(canvas.dataset.items ?? '[]') as ClientLogo[];
    initClientsPhysicsCanvas(canvas, items);
  };
  if ('requestIdleCallback' in window) {
    requestIdleCallback(initClientsIdle, { timeout: 2000 });
  } else {
    setTimeout(initClientsIdle, 200);
  }
  */

  // ── Constants ─────────────────────────────────────────────────────────────
  const TOTAL_SLIDES = 7;
  const ANIM_MS = 900;
  const WHEEL_THRESHOLD = 12;
  const TOUCH_THRESHOLD = 48;

  // % left for each service dot inside the dots-wrap
  const DOT_LEFTS = [7.5, 21, 34.5, 48, 61.5];
  // % left for clients/alliance logo position (relative to viewport)
  const CLIENTS_LOGO_PCT_MOBILE = 72;
  const CLIENTS_LOGO_PCT_TABLET = 78;
  const CLIENTS_LOGO_PCT_DESKTOP = 82;
  const SLIDE_POSITIONS = [
    { x: 0, y: 0 },
    { x: 1, y: 0 },
    { x: 1, y: 1 },
    { x: 2, y: 1 },
    { x: 2, y: 2 },
    { x: 1, y: 2 },
    { x: 3, y: 2 },
  ] as const;

  // ── DOM ───────────────────────────────────────────────────────────────────
  const section = document.querySelector<HTMLElement>('.js-about-snap');
  if (!section) throw new Error('AboutSnap: section not found');

  const stage = section.querySelector<HTMLElement>('.about-snap-stage');
  const slides = Array.from(section.querySelectorAll<HTMLElement>('.about-snap-slide'));
  const dots   = Array.from(section.querySelectorAll<HTMLElement>('.js-about-snap-dot'));
  const bar    = section.querySelector<HTMLElement>('.js-about-snap-bar');
  const progressEl = section.querySelector<HTMLElement>('.js-bar-progress');

  if (!stage) {
    throw new Error('AboutSnap: stage not found');
  }

  if (slides.length !== TOTAL_SLIDES) {
    throw new Error(`AboutSnap: expected ${TOTAL_SLIDES} slides, got ${slides.length}`);
  }

  // ── State ─────────────────────────────────────────────────────────────────
  let current = 0;
  let isAnimating = false;
  let isActive = false;
  let allianceDone = false;
  let alliancePlayed = false;
  // let clientsDropped = false;
  let touchStartY = 0;
  let lockedScrollY = 0;
  let previousHtmlOverflow = '';
  let previousBodyOverflow = '';
  let lastAboutTop = Number.POSITIVE_INFINITY;
  let lastScrollY = window.scrollY;
  let suppressAllianceAutoPlay = false;
  let suppressBackwardActivation = false;

  // ── Breakpoints ───────────────────────────────────────────────────────────
  const isMobile = () => window.matchMedia('(max-width: 767px)').matches;
  const isTablet = () => window.matchMedia('(min-width: 768px) and (max-width: 1024px)').matches;
  const getNavH  = () => document.querySelector<HTMLElement>('.site-nav')?.getBoundingClientRect().height ?? 0;
  const getIntroLogoY = () => window.innerHeight - (isMobile() ? 68 : isTablet() ? 72 : 70);

  // ── Logo helpers ──────────────────────────────────────────────────────────
  const getLogoScale = () => (isMobile() ? 0.58 : isTablet() ? 0.66 : 0.30);

  const syncLogoTooltipScale = (logo: HTMLElement) => {
    const tooltip = logo.querySelector<HTMLElement>('.scroll-consult-logo-tooltip');
    if (!tooltip) return;
    const scale = getLogoScale();
    if (scale > 0) {
      gsap.set(tooltip, {
        xPercent: -50,
        y: 0,
        scale: 0.68 / scale,
        autoAlpha: 1,
        transformOrigin: '50% 100%',
      });
    }
  };

  const positionLogo = (slideIdx: number, animate: boolean) => {
    const logo = document.querySelector<HTMLElement>('.js-scroll-consult-logo');
    if (!logo) return;

    if (!bar) return;
    const barRect = bar.getBoundingClientRect();
    let centerY = barRect.top + barRect.height / 2;
    let centerX: number;

    if (slideIdx === 0) {
      // Keep the bridge logo alive on the intro so the first service handoff is continuous.
      centerX = window.innerWidth / 2;
      centerY = getIntroLogoY();
    } else if (slideIdx >= 1 && slideIdx <= 5) {
      const dotRect = dots[slideIdx - 1]?.getBoundingClientRect();
      if (dotRect) {
        centerX = dotRect.left + dotRect.width / 2;
        centerY = dotRect.top + dotRect.height / 2;
      } else {
        const dotsWrap = section.querySelector<HTMLElement>('.about-snap-bar-dots-wrap');
        const wrapRect = dotsWrap?.getBoundingClientRect();
        centerX = wrapRect
          ? wrapRect.left + wrapRect.width * DOT_LEFTS[slideIdx - 1] / 100
          : window.innerWidth * DOT_LEFTS[slideIdx - 1] / 100;
      }
    } else {
      // Clients + Alliance: far-right logo zone
      const pct = isMobile()
        ? CLIENTS_LOGO_PCT_MOBILE
        : isTablet()
          ? CLIENTS_LOGO_PCT_TABLET
          : CLIENTS_LOGO_PCT_DESKTOP;
      centerX = window.innerWidth * pct / 100;
    }

    const logoVars = {
      left: centerX,
      top: centerY,
      x: 0,
      y: 0,
      xPercent: -50,
      yPercent: -50,
      scale: getLogoScale(),
      autoAlpha: 1,
      pointerEvents: 'auto',
      overwrite: true,
    } satisfies gsap.TweenVars;

    logo.classList.add('is-tooltip-visible');
    syncLogoTooltipScale(logo);

    if (animate) {
      gsap.to(logo, { ...logoVars, duration: 0.58, ease: 'power1.inOut' });
    } else {
      gsap.set(logo, logoVars);
    }
  };

  const updateDots = (slideIdx: number) => {
    dots.forEach((dot, i) => {
      const serviceIdx = i + 1; // service slides are 1-5
      dot.classList.toggle('is-active', slideIdx === serviceIdx);
      dot.classList.toggle('is-passed', slideIdx > serviceIdx || slideIdx >= 6);
    });

    if (progressEl) {
      let rightPct = 100 - DOT_LEFTS[0]; // 92.5 — zero progress
      if (slideIdx >= 2 && slideIdx <= 5) {
        rightPct = 100 - DOT_LEFTS[slideIdx - 1];
      } else if (slideIdx >= 6) {
        rightPct = 100 - DOT_LEFTS[4];
      }
      progressEl.style.right = `${rightPct}%`;
    }
  };

  // ── Video hydration ───────────────────────────────────────────────────────
  const loadSlideVideos = (slide: HTMLElement, shouldPlay: boolean) => {
    slide.querySelectorAll<HTMLVideoElement>('video[data-src]').forEach((v) => {
      if (v.dataset.src && !v.currentSrc) {
        v.src = v.dataset.src;
        v.load();
      }
      if (shouldPlay) {
        v.play().catch(() => {});
      } else {
        v.pause();
      }
    });
  };

  const hydrateSlide = (slide: HTMLElement) => loadSlideVideos(slide, true);

  const preloadSlide = (slide: HTMLElement | undefined) => {
    if (!slide) return;
    loadSlideVideos(slide, false);
  };

  const pauseSlide = (slide: HTMLElement) => {
    slide.querySelectorAll<HTMLVideoElement>('video').forEach((v) => v.pause());
  };

  const renderStage = (slideIdx: number) => {
    const position = SLIDE_POSITIONS[slideIdx];
    stage.style.transform = `translate3d(${-position.x * 100}%, ${-position.y * 100}%, 0)`;
  };

  const showOnlySlide = (slideIdx: number) => {
    slides.forEach((slide, i) => {
      slide.style.visibility = i === slideIdx ? 'visible' : 'hidden';
      slide.style.zIndex = i === slideIdx ? '2' : '1';
      slide.classList.toggle('is-active', i === slideIdx);
    });
  };

  // ── Clients physics drops ─────────────────────────────────────────────────
  /*
  const dispatchClientsDrops = () => {
    if (clientsDropped) return;
    clientsDropped = true;
    const stage = section.querySelector<HTMLElement>('.js-about-clients-stage');
    const fire = (impulse: number, delay: number) =>
      setTimeout(
        () => stage?.dispatchEvent(new CustomEvent('agsit-clients-drop', { detail: { impulse } })),
        delay,
      );
    fire(44, 120);
    fire(-58, 1500);
    fire(52, 2200);
    fire(-34, 2900);
  };
  */

  // ── Alliance animation ────────────────────────────────────────────────────
  const playAllianceZoom = () => {
    if (alliancePlayed) return;
    alliancePlayed = true;

    const allianceSlide   = slides[6];
    const floatingLogo    = document.querySelector<HTMLElement>('.js-scroll-consult-logo');
    const transitionLogo  = allianceSlide.querySelector<HTMLElement>('.js-about-transition-logo');
    const transitionVeil  = allianceSlide.querySelector<HTMLElement>('.js-about-transition-veil');
    const metricsEls      = Array.from(allianceSlide.querySelectorAll<HTMLElement>('.js-about-alliance-metric'));
    const allianceCopy    = Array.from(allianceSlide.querySelectorAll<HTMLElement>('.js-about-alliance-copy'));
    const allianceCta     = Array.from(allianceSlide.querySelectorAll<HTMLElement>('.js-about-alliance-cta'));

    if (!floatingLogo || !transitionLogo || !transitionVeil) return;

    const tl = gsap.timeline({
      onComplete: () => {
        allianceDone = true;
        // Auto-deactivate so the very next scroll naturally moves to VideoStory
        deactivate('forward');
      },
    });

    initAllianceLogoZoom({
      timeline: tl,
      startAt: 0,
      panelEl: allianceSlide,
      floatingLogoEl: floatingLogo,
      transitionLogoEl: transitionLogo,
      veilEl: transitionVeil,
      metricsEls,
      contentEls: [...allianceCopy, ...allianceCta],
    });
  };

  const prepareAllianceForBackwardReentry = () => {
    const allianceSlide = slides[6];

    gsap.set(allianceSlide, { backgroundColor: '#ffffff' });
    gsap.set(allianceSlide.querySelector('.js-about-transition-veil'), { autoAlpha: 0 });
    gsap.set(allianceSlide.querySelector('.js-about-transition-logo'), {
      autoAlpha: 0,
      scale: 0.68,
      x: 0,
      y: 0,
      xPercent: -50,
      yPercent: -50,
      rotate: 0,
      backgroundColor: 'rgba(2, 7, 18, 0)',
    });
    gsap.set(allianceSlide.querySelectorAll('.js-about-alliance-copy'), { autoAlpha: 1, y: 0 });
    gsap.set(allianceSlide.querySelectorAll('.js-about-alliance-metric'), { autoAlpha: 1, y: 0, scale: 1 });
    gsap.set(allianceSlide.querySelectorAll('.js-about-alliance-cta'), {
      autoAlpha: 1,
      y: 0,
      pointerEvents: 'auto',
    });
  };

  // ── On slide arrival ──────────────────────────────────────────────────────
  const onSlideArrival = (slideIdx: number, animate: boolean) => {
    section.dataset.currentSlide = String(slideIdx);
    updateDots(slideIdx);
    positionLogo(slideIdx, animate);

    /*
    if (slideIdx === 6) {
      // Reveal clients content (initially hidden by scroll controller)
      gsap.to(section.querySelectorAll('.js-about-clients-copy'), {
        autoAlpha: 1, y: 0, duration: 0.52, ease: 'power2.out',
      });
      gsap.to(section.querySelectorAll('.js-about-clients-stage'), {
        autoAlpha: 1, y: 0, scale: 1, duration: 0.62, ease: 'power2.out', delay: 0.1,
      });
      clientsDropped = false; // allow re-drop on re-entry
      dispatchClientsDrops();
    }
    */

    if (slideIdx === 6) {
      const allianceSlide = slides[6];
      if (suppressAllianceAutoPlay) {
        prepareAllianceForBackwardReentry();
        suppressAllianceAutoPlay = false;
      } else {
      if (alliancePlayed) {
        // Re-entry: reset state so zoom can replay cleanly
        gsap.set(allianceSlide.querySelector('.js-about-transition-veil'),  { autoAlpha: 0 });
        gsap.set(allianceSlide.querySelector('.js-about-transition-logo'),  {
          autoAlpha: 0, scale: 0.68, x: 0, y: 0, xPercent: -50, yPercent: -50, rotate: 0,
        });
        gsap.set(allianceSlide.querySelectorAll('.js-about-alliance-copy'),   { autoAlpha: 0, y: 24 });
        gsap.set(allianceSlide.querySelectorAll('.js-about-alliance-metric'), { autoAlpha: 0, y: 22, scale: 0.96 });
        gsap.set(allianceSlide.querySelectorAll('.js-about-alliance-cta'),    { autoAlpha: 0, y: 16, pointerEvents: 'none' });
        alliancePlayed = false;
        allianceDone   = false;
      }
      // 1. Reveal alliance content — zoom will then use it as "before" state and hide it
      gsap.to(allianceSlide.querySelectorAll('.js-about-alliance-copy'), {
        autoAlpha: 1, y: 0, duration: 0.7, ease: 'power2.out', delay: 0.15,
      });
      gsap.to(allianceSlide.querySelectorAll('.js-about-alliance-metric'), {
        autoAlpha: 1, y: 0, scale: 1, duration: 0.5, ease: 'power3.out', stagger: 0.08, delay: 0.4,
      });
      gsap.to(allianceSlide.querySelectorAll('.js-about-alliance-cta'), {
        autoAlpha: 1, y: 0, pointerEvents: 'auto', duration: 0.5, ease: 'power2.out', delay: 0.6,
      });
      // 2. Play zoom after content has been visible — zoom handles the exit transition to VideoStory
      setTimeout(playAllianceZoom, 1500);
      }
    }

    // Hydrate incoming video and warm the next slide before it enters.
    hydrateSlide(slides[slideIdx]);
    preloadSlide(slides[slideIdx + 1]);
  };

  // ── Navigation ────────────────────────────────────────────────────────────
  const navigate = (delta: number) => {
    if (isAnimating) return;

    const target = current + (delta > 0 ? 1 : -1);

    // Exit backward from intro
    if (target < 0) {
      deactivate('backward');
      return;
    }

    // Lock navigation while Alliance zoom is playing (can't navigate while veil transition runs)
    if (current === 6 && alliancePlayed && !allianceDone) return;

    // Exit forward from Alliance (only after zoom is done — but zoom auto-deactivates)
    if (target >= TOTAL_SLIDES) {
      if (allianceDone) deactivate('forward');
      return;
    }

    const currentEl = slides[current];
    const targetEl  = slides[target];

    section.dataset.currentSlide = String(target);
    updateDots(target);
    positionLogo(target, true);

    hydrateSlide(targetEl);
    preloadSlide(slides[target + 1]);

    targetEl.style.visibility = 'visible';
    targetEl.style.zIndex = '3';
    currentEl.style.zIndex = '2';

    stage.style.transition = 'transform 900ms cubic-bezier(0.76, 0, 0.24, 1)';
    renderStage(target);

    isAnimating = true;

    setTimeout(() => {
      currentEl.style.visibility = 'hidden';
      currentEl.style.zIndex = '1';
      targetEl.style.zIndex = '2';
      pauseSlide(currentEl);
      const prev = current;
      current = target;
      isAnimating = false;

      onSlideArrival(current, false);

      // Mark active on DOM for CSS hooks
      slides[prev].classList.remove('is-active');
      slides[current].classList.add('is-active');
    }, ANIM_MS);
  };

  // ── Activation / deactivation ─────────────────────────────────────────────
  const activate = (entry: 'normal' | 'from-below' = 'normal') => {
    if (isActive) return;

    if (entry === 'from-below') {
      current = TOTAL_SLIDES - 1;
      allianceDone = true;
      alliancePlayed = true;
      suppressAllianceAutoPlay = true;
      showOnlySlide(current);
      stage.style.transition = 'none';
      renderStage(current);
    }

    isActive = true;
    section.dataset.aboutState = 'active';
    previousHtmlOverflow = document.documentElement.style.overflow;
    previousBodyOverflow = document.body.style.overflow;

    // Snap section to exact viewport position (top = nav bottom)
    const navH = getNavH();
    const rect = section.getBoundingClientRect();
    lockedScrollY = window.scrollY + (rect.top - navH);
    if (Math.abs(rect.top - navH) > 0.5) {
      window.scrollTo({ top: lockedScrollY, behavior: 'instant' });
    }

    // Lock page scroll — section controls the experience from here
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';

    onSlideArrival(current, false);
  };

  const deactivate = (reason: 'backward' | 'forward') => {
    if (!isActive) return;
    isActive = false;

    // Unlock page scroll
    document.documentElement.style.overflow = previousHtmlOverflow;
    document.body.style.overflow = previousBodyOverflow;

    if (reason === 'forward') {
      section.dataset.aboutState = 'done';
      gsap.set('.js-scroll-consult-logo', { autoAlpha: 0, pointerEvents: 'none' });
      const navH = getNavH();
      const sectionTop = lockedScrollY || window.scrollY + section.getBoundingClientRect().top - navH;
      window.scrollTo({ top: sectionTop + section.offsetHeight + 1, behavior: 'instant' });
    } else {
      // Reset so bridge takes over when scrolling back up
      delete section.dataset.aboutState;
      const navH = getNavH();
      const sectionTop = lockedScrollY || window.scrollY + section.getBoundingClientRect().top - navH;
      // Reset slide state to 0 for next entry
      if (current !== 0) {
        slides[current].style.visibility = 'hidden';
        slides[current].style.zIndex = '1';
        slides[current].classList.remove('is-active');
        slides[0].style.visibility = 'visible';
        slides[0].style.zIndex = '2';
        slides[0].classList.add('is-active');
        stage.style.transition = 'none';
        renderStage(0);
        current = 0;
        allianceDone   = false;
        alliancePlayed = false;
        // clientsDropped = false;
        updateDots(0);
      }
      const releaseY = Math.max(0, sectionTop - navH - 2);
      suppressBackwardActivation = true;
      window.scrollTo({ top: releaseY, behavior: 'instant' });
      lastScrollY = releaseY;
      lastAboutTop = Number.POSITIVE_INFINITY;
      window.setTimeout(() => {
        suppressBackwardActivation = false;
        lastAboutTop = section.getBoundingClientRect().top;
        lastScrollY = window.scrollY;
      }, 180);
    }
  };

  // ── Scroll-based activation check ────────────────────────────────────────
  const checkActivation = () => {
    if (isActive || isAnimating) return;
    const currentScrollY = window.scrollY;
    const isScrollingUp = currentScrollY < lastScrollY;
    lastScrollY = currentScrollY;
    const navH = getNavH();
    const rect = section.getBoundingClientRect();

    if (suppressBackwardActivation) {
      lastAboutTop = rect.top;
      return;
    }

    if (section.dataset.aboutState === 'done') {
      if (isScrollingUp && rect.top <= navH && rect.bottom > navH) {
        activate('from-below');
      }
      return;
    }

    const crossedNav = lastAboutTop > navH && rect.top <= navH;
    const isAtPanel = rect.top <= navH && rect.bottom > navH;
    const skippedPanel = crossedNav && rect.bottom <= navH;
    lastAboutTop = rect.top;

    // Activate when the section reaches the nav, including fast-scroll cases
    // that land just beyond the section before this listener runs.
    if (isAtPanel || skippedPanel) {
      activate();
    }
  };

  window.addEventListener('scroll', checkActivation, { passive: true });

  // ── Wheel handler ─────────────────────────────────────────────────────────
  const onWheel = (e: WheelEvent) => {
    if (!isActive) return;
    e.preventDefault();
    if (Math.abs(e.deltaY) < WHEEL_THRESHOLD) return;
    navigate(Math.sign(e.deltaY));
  };

  // ── Touch handlers ────────────────────────────────────────────────────────
  const onTouchStart = (e: TouchEvent) => {
    if (!isActive) return;
    touchStartY = e.touches[0].clientY;
  };

  const onTouchMove = (e: TouchEvent) => {
    if (!isActive) return;
    e.preventDefault();
  };

  const onTouchEnd = (e: TouchEvent) => {
    if (!isActive) return;
    const dy = touchStartY - e.changedTouches[0].clientY;
    if (Math.abs(dy) < TOUCH_THRESHOLD) return;
    navigate(Math.sign(dy));
  };

  // Listeners on window so they fire regardless of cursor position within viewport
  window.addEventListener('wheel',      onWheel,      { passive: false });
  window.addEventListener('touchstart', onTouchStart, { passive: true });
  window.addEventListener('touchmove',  onTouchMove,  { passive: false });
  window.addEventListener('touchend',   onTouchEnd,   { passive: true });

  // ── Initial slide state ───────────────────────────────────────────────────
  stage.style.transition = 'none';
  slides.forEach((slide, i) => {
    const position = SLIDE_POSITIONS[i];
    slide.style.transform = `translate3d(${position.x * 100}%, ${position.y * 100}%, 0)`;
    slide.style.zIndex = i === 0 ? '2' : '1';
    if (i === 0) {
      slide.style.visibility = 'visible';
      slide.classList.add('is-active');
    } else {
      slide.style.visibility = 'hidden';
    }
  });
  renderStage(0);
  updateDots(0);
  preloadSlide(slides[1]);
</script>
