---
import { Image } from 'astro:assets';
import type { AboutContent } from '../../data/about';
import { clientLogos } from '../../data/about';
import logoImage from '../../assets/images/logo-asit.webp';

type Props = {
  content: AboutContent;
};

const { content } = Astro.props;
---

<section id="servicios" class="about-horizontal-section js-about-horizontal" aria-label={content.sectionLabel}>
  <div class="about-horizontal-track js-about-track">
    <article class="about-panel about-panel-question about-panel-overview">
      <div class="about-overview">
        <p class="about-overview-kicker js-about-intro-fade">{content.overview.kicker}</p>
        <h2 class="about-overview-title js-about-intro-fade">
          {content.overview.title}
          <span>{content.overview.titleAccent}</span>
        </h2>
        <p class="about-overview-copy js-about-intro-fade">
          {content.overview.copy}
        </p>
        <p class="about-overview-scroll js-about-intro-fade">{content.overview.scroll}</p>
      </div>
    </article>

    {
      content.services.map((service) => (
        <article class="about-panel about-panel-services">
          <article class="about-service-story js-about-service-card">
            <div class="about-service-image-frame js-about-service-visual" aria-label={service.alt}>
              <video
                data-src={service.image}
                poster="/assets/fondo-ventana.webp"
                autoplay
                muted
                loop
                playsinline
                preload="none"
              ></video>
            </div>
            <div class="about-service-body js-about-service-body">
              <p class="about-service-number" aria-hidden="true">
                {service.number}
              </p>
              <p class="about-service-code">
                {service.code} - {service.label}
              </p>
              <h3>{service.title}</h3>
              <p class="about-service-description">{service.description}</p>
              <div class="about-service-tags">
                {service.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
              {
                service.href ? (
                  <a class="about-service-link" href={service.href}>
                    {content.serviceLinkLabel} {service.code} →
                  </a>
                ) : (
                  <p class="about-service-link">
                    {content.serviceLinkLabel} {service.code} →
                  </p>
                )
              }
            </div>
          </article>
        </article>
      ))
    }

    <article class="about-panel about-panel-clients">
      <div class="about-clients-copy js-about-clients-copy">
        <h2>{content.clients.title}</h2>
        <p>{content.clients.copy}</p>
      </div>
      <div class="about-clients-stage js-about-clients-stage">
        <canvas class="about-clients-canvas" aria-hidden="true" data-items={JSON.stringify(clientLogos)} />
      </div>
    </article>

    <article class="about-panel about-panel-alliances">
      <div class="about-transition-veil js-about-transition-veil" aria-hidden="true"></div>
      <div class="about-alliance-layout">
        <div class="about-alliance-copy js-about-alliance-copy">
          <h2 class="about-alliance-title" aria-label={content.alliance.titleLabel}>
            {content.alliance.titleLines.map((line) => (
              <span class="about-alliance-title-line">{line}</span>
            ))}
          </h2>
          <p>{content.alliance.copy}</p>
        </div>
        <div class="about-transition-logo js-about-transition-logo" aria-hidden="true">
          <Image class="about-transition-logo-image" src={logoImage} alt="" loading="lazy" draggable="false" />
        </div>
        <div class="about-alliance-triangle-wrap" aria-hidden="true">
          <span class="about-alliance-metric about-alliance-metric-scope js-about-alliance-metric">
            {content.alliance.metrics.scope}
          </span>
          <div class="about-alliance-triangle-spacer"></div>
          <div class="about-alliance-triangle-bottom">
            <span class="about-alliance-metric about-alliance-metric-cost js-about-alliance-metric pl-9">
              {content.alliance.metrics.cost}
            </span>
            <span class="about-alliance-metric about-alliance-metric-time js-about-alliance-metric max-sm:pr-8">
              {content.alliance.metrics.time}
            </span>
          </div>
        </div>
        <button class="about-alliance-cta js-about-alliance-cta" type="button" data-contact-trigger>
          {content.alliance.cta}
        </button>
      </div>
    </article>
  </div>
  <div class="about-timeline-nav js-about-timeline" aria-hidden="true">
    <div class="about-timeline-line js-about-timeline-line"></div>
    <div class="about-timeline-progress js-about-timeline-progress"></div>
    {content.services.map((_, i) => (
      <div class="about-timeline-stop js-about-timeline-stop">
        <span class="about-timeline-number">{i + 1}</span>
      </div>
    ))}
  </div>
</section>

<script>
  import { initClientsPhysicsCanvas } from './clientsPhysicsCanvas';
  import type { ClientLogo } from '../../data/about';

  const initWhenIdle = () => {
    const canvas = document.querySelector<HTMLCanvasElement>('.about-clients-canvas');
    if (!canvas) return;
    const items = JSON.parse(canvas.dataset.items ?? '[]') as ClientLogo[];
    initClientsPhysicsCanvas(canvas, items);
  };

  if ('requestIdleCallback' in window) {
    requestIdleCallback(initWhenIdle, { timeout: 2000 });
  } else {
    setTimeout(initWhenIdle, 200);
  }
</script>
