---
import FinalContactSection from '../final-contact/FinalContactSection.astro';
import ServicePageAnimations from '../service-animation/ServicePageAnimations.astro';
import type { ContactCopy } from '../../data/contact';
import type { ProcessManagementContent } from '../../data/processManagement';

type Props = {
  content: ProcessManagementContent;
  contactCopy: ContactCopy;
};

const { content, contactCopy } = Astro.props;
---

<main class="process-page">
  <section class="process-hero" aria-labelledby="process-hero-title">
    <div class="process-hero-copy">
      <p class="process-eyebrow">{content.hero.eyebrow}</p>
      <h1 id="process-hero-title">{content.hero.title}</h1>
      <p>{content.hero.copy}</p>
      <div class="process-hero-actions">
        <button type="button" data-contact-trigger>{content.hero.primaryCta}</button>
        <a href="#metodologia">{content.hero.secondaryCta}</a>
      </div>
    </div>

    <div class="process-map" aria-hidden="true">
      <div class="process-map-grid"></div>
      {content.hero.nodes.map((node, index) => <span class={`process-node process-node-${index + 1}`}>{node}</span>)}
      <svg viewBox="0 0 520 360">
        <path d="M74 96 C168 40 252 80 326 138 S430 224 462 276" />
        <path d="M98 250 C166 198 236 204 302 236 S410 304 470 216" />
      </svg>
    </div>
  </section>

  <section class="process-video" aria-labelledby="process-video-title">
    <div class="process-video-copy">
      <p class="process-eyebrow">{content.video.eyebrow}</p>
      <h2 id="process-video-title">{content.video.title}</h2>
      <p>{content.video.copy}</p>
    </div>

    <div class="process-video-panel">
      <video controls preload="metadata" playsinline aria-label={content.video.label}>
        <source src={content.video.src} type="video/mp4" />
      </video>
    </div>
  </section>

  <section id="metodologia" class="process-pillars" aria-labelledby="process-pillars-title">
    <div class="process-section-heading">
      <p class="process-eyebrow">{content.pillars.eyebrow}</p>
      <h2 id="process-pillars-title">{content.pillars.title}</h2>
      <p>{content.pillars.copy}</p>
    </div>

    <div class="process-pillar-grid">
      {
        content.pillars.items.map((item) => (
          <article class="process-pillar">
            <span>{item.code}</span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
            <ul>
              {item.points.map((point) => (
                <li>{point}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="process-flow" aria-labelledby="process-flow-title">
    <div class="process-flow-copy">
      <h2 id="process-flow-title">{content.flow.title}</h2>
      <p>{content.flow.copy}</p>
    </div>
    <div class="process-flow-steps">
      {
        content.flow.steps.map((step) => (
          <article>
            <span>{step.label}</span>
            <h3>{step.title}</h3>
            <p>{step.copy}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="process-control" aria-labelledby="process-control-title">
    <div class="process-section-heading">
      <p class="process-eyebrow">{content.control.eyebrow}</p>
      <h2 id="process-control-title">{content.control.title}</h2>
      <p>{content.control.copy}</p>
    </div>
    <div class="process-metric-grid">
      {
        content.control.metrics.map((metric) => (
          <article>
            <strong>{metric.value}</strong>
            <h3>{metric.label}</h3>
            <p>{metric.copy}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="process-outcomes" aria-labelledby="process-outcomes-title">
    <h2 id="process-outcomes-title">{content.outcomes.title}</h2>
    <ul>
      {content.outcomes.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <FinalContactSection copy={contactCopy} />

  <ServicePageAnimations />
</main>
