---
import { Image } from 'astro:assets';
import type { FooterCopy } from '../../data/footer';
import type { ServiceItem } from '../../data/services';
import logoImage from '../../assets/images/logo-asit.webp';

type Props = {
  copy: FooterCopy;
  services: ServiceItem[];
};

const { copy, services } = Astro.props;
---

<footer class="site-footer">
  <div class="footer-brand">
    <Image src={logoImage} alt="Logo AGSIT" loading="lazy" />
    <p>{copy.brand}</p>
  </div>

  <div>
    <h4>{copy.menuTitle}</h4>
    <a href="#inicio">{copy.nav.home}</a>
    <a href="#servicios">{copy.nav.services}</a>
    <a href="#contacto">{copy.nav.contact}</a>
  </div>

  <div>
    <h4>{copy.servicesTitle}</h4>
    {
      services.map((service) => (
        <span>{service.title}</span>
      ))
    }
  </div>

  <div>
    <h4>{copy.contactTitle}</h4>
    <span>{copy.location}</span>
    <a href="mailto:contacto@agsit.com.mx">contacto@agsit.com.mx</a>
    <a href="tel:+525588905291">+52 55 8890 5291</a>
    <a href="tel:+525570267458">+52 55 7026 7458</a>
  </div>
</footer>
