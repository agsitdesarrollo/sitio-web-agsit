---
import SeoHead from '../components/seo/SeoHead.astro';
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  htmlLang?: string;
  locale?: string;
  alternates?: Array<{ lang: string; href: string }>;
};

const { title, description, canonicalUrl, htmlLang = 'es-MX', locale, alternates = [] } = Astro.props;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@300;400;500;600;700;800&display=swap"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <SeoHead title={title} description={description} canonicalUrl={canonicalUrl} locale={locale} alternates={alternates} />
  </head>
  <body>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        let frame = 0;
        const applyViewportHeight = () => {
          const height = window.visualViewport?.height || window.innerHeight;
          root.style.setProperty('--app-vh', `${height}px`);
          window.dispatchEvent(new CustomEvent('agsit:viewport-change'));
        };
        const scheduleViewportHeight = () => {
          cancelAnimationFrame(frame);
          frame = requestAnimationFrame(applyViewportHeight);
        };

        applyViewportHeight();
        window.visualViewport?.addEventListener('resize', scheduleViewportHeight, { passive: true });
        window.addEventListener('resize', scheduleViewportHeight, { passive: true });
        window.addEventListener('orientationchange', scheduleViewportHeight, { passive: true });
        window.addEventListener('pageshow', scheduleViewportHeight, { passive: true });
      })();
    </script>
    <slot />
  </body>
</html>
