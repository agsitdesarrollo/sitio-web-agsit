---
import SeoHead from '../components/seo/SeoHead.astro';
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  htmlLang?: string;
  locale?: string;
  alternates?: Array<{ lang: string; href: string }>;
};

const { title, description, canonicalUrl, htmlLang = 'es-MX', locale, alternates = [] } = Astro.props;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preload" href="/fonts/inter-normal-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/cormorant-garamond-normal-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/fonts/fonts.css" />
    <!-- <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" /> -->
    <link rel="icon" href="/AGSIT-Logo-512x512-2-150x150.png" />
    <SeoHead title={title} description={description} canonicalUrl={canonicalUrl} locale={locale} alternates={alternates} />
  </head>
  <body>
    <script is:inline>
      (() => {
        const root = document.documentElement;
        const compactQuery = window.matchMedia('(max-width: 900px)');
        const shortLandscapeQuery = window.matchMedia(
          '(pointer: coarse) and (orientation: landscape) and (max-width: 932px) and (max-height: 520px)',
        );
        let frame = 0;
        let stableHeight = 0;
        let lastDynamicHeight = 0;
        let lastWidth = window.innerWidth;
        let handoffViewportLocked = false;
        let pendingViewportReason = '';
        let pendingViewportForceStable = false;

        const getDynamicHeight = () => Math.round(window.visualViewport?.height || window.innerHeight);
        const getStableCandidate = () => Math.round(Math.max(window.innerHeight, getDynamicHeight()));

        const applyViewportHeight = (reason = 'resize', forceStable = false) => {
          if (handoffViewportLocked) {
            pendingViewportReason = reason;
            pendingViewportForceStable ||= forceStable;
            return;
          }

          const dynamicHeight = getDynamicHeight();
          const stableCandidate = getStableCandidate();
          const width = window.innerWidth;
          const isCompact = compactQuery.matches;
          const widthChanged = Math.abs(width - lastWidth) > 24;
          const dynamicChanged = Math.abs(dynamicHeight - lastDynamicHeight) > 1;
          let stableChanged = false;

          root.style.setProperty('--app-vh', `${dynamicHeight}px`);

          if (!stableHeight || !isCompact || forceStable || widthChanged) {
            stableHeight = stableCandidate;
            root.style.setProperty('--app-stable-vh', `${stableHeight}px`);
            stableChanged = true;
          }

          lastDynamicHeight = dynamicHeight;
          lastWidth = width;

          // En teléfonos horizontales el alto cambia al aparecer/desaparecer la
          // UI de Chrome. La sección de alianza usa ese alto dentro de una
          // timeline, así que necesita recibir el evento para recalcular sus
          // coordenadas. El resto de compactos conserva la política estable.
          if (stableChanged || !isCompact || (shortLandscapeQuery.matches && dynamicChanged)) {
            window.dispatchEvent(
              new CustomEvent('agsit:viewport-change', {
                detail: {
                  reason,
                  stableChanged,
                  dynamicChanged,
                  dynamicHeight,
                  stableHeight,
                },
              }),
            );
          }
        };

        const scheduleViewportHeight = (reason = 'resize', forceStable = false) => {
          cancelAnimationFrame(frame);
          frame = requestAnimationFrame(() => applyViewportHeight(reason, forceStable));
        };

        applyViewportHeight('load', true);
        window.visualViewport?.addEventListener('resize', () => scheduleViewportHeight('visual-resize'), {
          passive: true,
        });
        window.addEventListener('resize', () => scheduleViewportHeight('resize'), { passive: true });
        window.addEventListener(
          'orientationchange',
          () => {
            scheduleViewportHeight('orientationchange', true);
            window.setTimeout(() => scheduleViewportHeight('orientationchange-settled', true), 240);
          },
          { passive: true },
        );
        window.addEventListener('pageshow', () => scheduleViewportHeight('pageshow', true), { passive: true });
        window.addEventListener('agsit:handoff-viewport-lock', () => {
          handoffViewportLocked = true;
        });
        window.addEventListener('agsit:handoff-viewport-unlock', () => {
          handoffViewportLocked = false;
          scheduleViewportHeight(pendingViewportReason || 'handoff-unlock', pendingViewportForceStable);
          pendingViewportReason = '';
          pendingViewportForceStable = false;
        });
      })();
    </script>
    <slot />
  </body>
</html>
